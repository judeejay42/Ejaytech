              </div>
              <div class="col-6">
                <p class="mb-0">___________________________</p>
                <p class="small">Registrar Stamp & Approval</p>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer no-print border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
          <button type="button" class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer"></i> Print Course Slip</button>
        </div>
