<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Command Center - EJaytech Concepts</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" id="bootstrap-css">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" id="bootstrap-icons">
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="assets/images/logo-512.png">
  <!-- Custom Core CSS -->
  <link href="css/style.css" rel="stylesheet" id="custom-style">

  <style>
    /* Premium Dashboard Layout & Styles */
    :root {
      --sidebar-width: 280px;
      --header-height: 70px;
      --transition-speed: 0.3s;
    }

    /* Dark Mode Variable Overrides */
    body.dark-theme {
      --color-bg-light: #0f172a;
      --color-bg-card: #1e293b;
      --color-text-main: #f8fafc;
      --color-text-muted: #94a3b8;
      --color-border: #334155;
      background-color: var(--color-bg-light);
      color: var(--color-text-main);
    }

    body.dark-theme .card, 
    body.dark-theme .modal-content,
    body.dark-theme .offcanvas,
    body.dark-theme .dropdown-menu {
      background-color: var(--color-bg-card);
      border-color: var(--color-border);
      color: var(--color-text-main);
    }

    body.dark-theme h1, 
    body.dark-theme h2, 
    body.dark-theme h3, 
    body.dark-theme h4, 
    body.dark-theme h5, 
    body.dark-theme h6,
    body.dark-theme .text-dark,
    body.dark-theme .form-control,
    body.dark-theme .form-select {
      color: var(--color-text-main) !important;
    }

    body.dark-theme .form-control,
    body.dark-theme .form-select {
      background-color: #1e293b;
      border-color: #334155;
    }

    body.dark-theme .table {
      color: var(--color-text-main);
      border-color: #334155;
    }

    body.dark-theme .table th,
    body.dark-theme .table td {
      border-color: #334155;
    }

    body.dark-theme .list-group-item {
      background-color: var(--color-bg-card);
      border-color: var(--color-border);
      color: var(--color-text-main);
    }

    body.dark-theme .bg-light {
      background-color: #0f172a !important;
    }

    /* Layout Frame Structure */
    #dashboard-wrapper {
      display: flex;
      min-height: 100vh;
      width: 100%;
    }

    /* Modern Premium Sidebar */
    #sidebar {
      width: var(--sidebar-width);
      background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
      color: #94a3b8;
      flex-shrink: 0;
      transition: all var(--transition-speed) ease;
      z-index: 100;
      border-right: 1px solid var(--color-border);
    }

    #sidebar .nav-link {
      color: #94a3b8;
      padding: 0.75rem 1.25rem;
      margin: 0.2rem 1rem;
      border-radius: 8px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: all 0.2s ease;
    }

    #sidebar .nav-link:hover {
      color: #ffffff;
      background-color: rgba(255, 255, 255, 0.05);
    }

    #sidebar .nav-link.active {
      color: #ffffff;
      background-color: #2563eb;
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.35);
    }

    /* Content Stage Area */
    #content-stage {
      flex-grow: 1;
      min-width: 0;
      display: flex;
      flex-column: column;
      background-color: var(--color-bg-light);
    }

    /* Floating Navigation Header */
    #portal-header {
      height: var(--header-height);
      background-color: var(--color-bg-card);
      border-bottom: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      position: sticky;
      top: 0;
      z-index: 90;
    }

    /* Timeline Admission Stepper */
    .timeline-stepper {
      display: flex;
      justify-content: space-between;
      position: relative;
      margin-bottom: 2rem;
      padding-top: 1rem;
    }

    .timeline-stepper::before {
      content: '';
      position: absolute;
      top: 2.2rem;
      left: 10%;
      right: 10%;
      height: 4px;
      background-color: var(--color-border);
      z-index: 1;
    }

    .timeline-step {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 20%;
    }

    .step-icon {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background-color: var(--color-bg-card);
      border: 3px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      transition: all 0.3s ease;
      color: var(--color-text-muted);
    }

    .timeline-step.active .step-icon {
      border-color: #2563eb;
      color: #2563eb;
      background-color: #eff6ff;
    }

    .timeline-step.completed .step-icon {
      border-color: #10b981;
      background-color: #10b981;
      color: white;
    }

    .step-label {
      margin-top: 0.5rem;
      font-size: 0.78rem;
      font-weight: 600;
      text-align: center;
    }

    /* Profile Passport Frame */
    .passport-photo-frame {
      position: relative;
      width: 140px;
      height: 140px;
      border-radius: 12px;
      border: 4px solid var(--color-bg-card);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      margin: 0 auto 1rem;
      background-color: #f1f5f9;
    }

    .passport-photo-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Responsive Overlay sidebar toggles */
    @media (max-width: 991.98px) {
      #sidebar {
        position: fixed;
        left: -100%;
        top: 0;
        bottom: 0;
        width: var(--sidebar-width);
        z-index: 1050;
      }
      #sidebar.show {
        left: 0;
      }
      .sidebar-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1040;
        display: none;
      }
      .sidebar-backdrop.show {
        display: block;
      }
    }

    /* Print styling templates */
    @media print {
      body {
        background-color: #ffffff !important;
        color: #000000 !important;
      }
      #sidebar, #portal-header, .btn, .no-print {
        display: none !important;
      }
      #content-stage {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
      }
      .print-visible {
        display: block !important;
      }
    }

    /* Beautiful Branded Receipt */
    .branded-receipt {
      border: 2px solid #e2e8f0;
      padding: 2.5rem;
      border-radius: 12px;
      background-color: #ffffff;
      color: #0f172a;
      max-width: 600px;
      margin: 0 auto;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>
<body class="bg-light">

  <div id="dashboard-wrapper">
    
    <!-- LEFT SIDEBAR NAVIGATION PANEL -->
    <aside id="sidebar" class="d-flex flex-column justify-content-between">
      <div>
        <!-- Sidebar Brand Logo Header -->
        <div class="p-4 d-flex align-items-center gap-3 border-bottom border-secondary border-opacity-10">
          <img src="/assets/images/logo-512.png" alt="EJaytech Logo" style="width: 46px; height: 46px; object-fit: contain;">
          <div>
            <span class="fw-bold text-white font-display d-block" style="font-size: 1.1rem; letter-spacing: -0.5px;">EJaytech Concepts</span>
            <span class="small text-muted d-block" style="font-size: 0.68rem; letter-spacing: 0.5px; text-transform: uppercase;">Student Portal</span>
          </div>
        </div>

        <!-- Scrollable Navigation Hub -->
        <div class="py-3 overflow-y-auto" style="max-height: calc(100vh - 160px);">
          <nav class="nav flex-column font-display" id="nav-hub-links">
            <a href="#" class="nav-link active" data-target="sec-dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
            <a href="#" class="nav-link" data-target="sec-profile"><i class="bi bi-person-badge-fill"></i> My Profile</a>
            <a href="#" class="nav-link" data-target="sec-academic"><i class="bi bi-mortarboard-fill"></i> Academic Info</a>
            <a href="#" class="nav-link" data-target="sec-courses"><i class="bi bi-journal-bookmark-fill"></i> My Courses</a>
            <a href="#" class="nav-link" data-target="sec-documents"><i class="bi bi-file-earmark-text-fill"></i> Documents</a>
            <a href="#" class="nav-link text-white text-opacity-75" data-target="sec-payments"><i class="bi bi-wallet2"></i> Payments & Finance</a>
            <a href="#" class="nav-link" data-target="sec-announcements"><i class="bi bi-megaphone-fill"></i> Announcements</a>
            <a href="#" class="nav-link text-white text-opacity-75" data-target="sec-resources"><i class="bi bi-folder-symlink-fill"></i> Learning Materials <span class="badge bg-secondary ms-auto locked-nav-badge d-none"><i class="bi bi-lock-fill"></i></span></a>
            <a href="#" class="nav-link text-white text-opacity-75" data-target="sec-results"><i class="bi bi-award-fill"></i> Results & Grades <span class="badge bg-secondary ms-auto locked-nav-badge d-none"><i class="bi bi-lock-fill"></i></span></a>
            <a href="#" class="nav-link text-white text-opacity-75" data-target="sec-certificates"><i class="bi bi-patch-check-fill"></i> Certificates <span class="badge bg-secondary ms-auto locked-nav-badge d-none"><i class="bi bi-lock-fill"></i></span></a>
            <a href="#" class="nav-link text-white text-opacity-75" data-target="sec-attendance"><i class="bi bi-calendar-check-fill"></i> Attendance <span class="badge bg-secondary ms-auto locked-nav-badge d-none"><i class="bi bi-lock-fill"></i></span></a>
            <a href="#" class="nav-link" data-target="sec-instructors"><i class="bi bi-people-fill"></i> Instructors</a>
            <a href="#" class="nav-link" data-target="sec-timetable"><i class="bi bi-calendar3"></i> Timetable</a>
            <a href="#" class="nav-link" data-target="sec-messages"><i class="bi bi-chat-dots-fill"></i> Messages <span class="badge bg-danger rounded-pill float-end" id="messages-unseen-badge" style="display: none;">0</span></a>
            <a href="#" class="nav-link" data-target="sec-notifications"><i class="bi bi-bell-fill"></i> Notifications <span class="badge bg-primary ms-auto" id="notif-badge-pill">0</span></a>
            <a href="#" class="nav-link" data-target="sec-support"><i class="bi bi-question-circle-fill"></i> Support Desk</a>
            <a href="#" class="nav-link" data-target="sec-settings"><i class="bi bi-gear-wide-connected"></i> Settings</a>
          </nav>
        </div>
      </div>

      <!-- Sidebar Sign-out Footer Trigger -->
      <div class="p-3 border-top border-secondary border-opacity-10">
        <button onclick="triggerSignoutModal()" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2 py-2"><i class="bi bi-box-arrow-right"></i> Sign Out</button>
      </div>
    </aside>

    <!-- Sidebar Responsive Overlay backdrop -->
    <div class="sidebar-backdrop" id="sidebar-backdrop" onclick="toggleMobileSidebar()"></div>

    <!-- MAIN DASHBOARD HUB CONTENT STAGE -->
    <div id="content-stage" class="d-flex flex-column">

      <!-- TOP HUB FLOATING NAVIGATION HEADER -->
      <header id="portal-header">
        <div class="d-flex align-items-center gap-3">
          <!-- Mobile Menu Hamburger toggler -->
          <button class="btn btn-light d-lg-none border" onclick="toggleMobileSidebar()"><i class="bi bi-list fs-4"></i></button>
          
          <div class="d-none d-sm-block">
            <h5 class="fw-bold text-dark font-display mb-0" id="navbar-view-title">Command Workspace</h5>
            <span class="small text-muted" id="navbar-centre-badge">EJaytech Concepts Abuja Hub</span>
          </div>
        </div>

        <div class="d-flex align-items-center gap-3">
          <!-- Quick Status Pill Indicators -->
          <span class="badge bg-success-subtle text-success border py-2 px-3 fw-bold rounded-pill" id="quick-admission-badge">Admission Approved</span>
          
          <!-- Student Avatar quick drop trigger -->
          <div class="dropdown">
            <button class="btn btn-light border p-1 rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 44px; height: 44px;">
              <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center w-100 h-100 fw-bold" id="navbar-avatar-initials">ST</div>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
              <li class="px-3 py-2 border-bottom">
                <span class="fw-bold d-block text-dark text-truncate" style="max-width: 180px;" id="navbar-dropdown-name">Student Full Name</span>
                <span class="small text-muted text-truncate d-block" style="max-width: 180px;" id="user-display-email">student@example.com</span>
              </li>
              <li><a class="dropdown-item py-2" href="#" onclick="switchView('sec-profile')"><i class="bi bi-person-fill me-2 text-primary"></i> Edit Profile</a></li>
              <li><a class="dropdown-item py-2" href="#" onclick="switchView('sec-settings')"><i class="bi bi-gear me-2 text-primary"></i> Settings</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><button class="dropdown-item py-2 text-danger" onclick="triggerSignoutModal()"><i class="bi bi-box-arrow-right me-2"></i> Log Out</button></li>
            </ul>
          </div>
        </div>
      </header>

      <!-- ACTIVE WINDOW VIEW CONTAINER -->
      <main class="p-4 flex-grow-1" id="workspace-view-holder">

        <!-- GLOBAL LOADER SCREEN -->
        <div class="text-center py-5" id="dash-loading-screen">
          <div class="spinner-border text-primary" role="status" style="width: 3.5rem; height: 3.5rem;">
            <span class="visually-hidden">Syncing session...</span>
          </div>
          <p class="text-muted mt-3 font-display" id="dash-loading-text">Authenticating...</p>
        </div>

        <!-- ERROR/NOTICE COMPONENT SCREEN -->
        <div class="text-center py-5 d-none mx-auto" id="dash-error-screen" style="max-width: 500px;">
          <div class="rounded-circle p-3 mb-3 d-inline-flex justify-content-center align-items-center bg-danger-subtle text-danger" style="width: 70px; height: 70px;">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 2.2rem;"></i>
          </div>
          <h4 class="fw-bold text-dark font-display mb-3" id="dash-error-title">Unable to Load Profile</h4>
          <p class="text-secondary mb-4 leading-relaxed id-error-msg" id="dash-error-message"></p>
          <div class="d-flex flex-column gap-2 justify-content-center align-items-center" id="dash-error-actions"></div>
        </div>

        <!-- PENDING OVERLAY STATE NOTICE -->
        <div class="p-4 rounded-3 border bg-warning-subtle text-warning-dark border-warning mb-4 d-none" id="pending-status-overlay">
          <div class="d-flex align-items-start gap-3">
            <span class="fs-1 text-warning"><i class="bi bi-person-fill-exclamation"></i></span>
            <div>
              <h4 class="fw-bold font-display mb-2 text-dark">Enrollment Review Notice</h4>
              <p class="mb-3 text-dark" style="opacity: 0.95;">
                Welcome! Your vocational training enrollment is currently listed as <span class="badge bg-warning text-dark fw-bold">PENDING REGISTRATION CHECKS</span>.
              </p>
              <p class="mb-0 text-muted small">
                While our registrar conducts document checks and verifies tuition logs at our Garki Abuja central hub (Suite B18 Garki Plaza), you are welcome to pre-read class manuals, view syllabi, and keep your contact details updated below.
              </p>
            </div>
          </div>
        </div>

        <!-- ==================== VIEW MODULES (SWAPPED BY SIDEBAR LINKS) ==================== -->
        <div id="active-dashboard-grid" class="d-none">

          <!-- 1. VIEW: DASHBOARD OVERVIEW -->
          <div id="sec-dashboard" class="dashboard-view-module">
            <!-- Greeting Welcome banner -->
            <div class="card border-0 rounded-4 p-4 text-white shadow-sm mb-4" style="background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);">
              <div class="row align-items-center g-3">
                <div class="col-md-8">
                  <h2 class="fw-bold font-display mb-1">Welcome Back, <span id="student-fullname-display">Student</span>!</h2>
                  <p class="mb-0 opacity-90 small">Keep learning, build projects, and unlock professional certifications at EJaytech Concepts.</p>
                </div>
                <div class="col-md-4 text-md-end">
                  <span class="small font-mono bg-white bg-opacity-20 py-2 px-3 rounded-3 d-inline-block text-white" id="live-portal-clock">10:49 AM | Garki Center</span>
                </div>
              </div>
            </div>

            <!-- PROMINENT REGISTRATION STATUS CARD -->
            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4" id="registration-status-card" style="background: #ffffff;">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                <div class="d-flex align-items-center gap-2">
                  <span class="fs-4 text-primary"><i class="bi bi-shield-check"></i></span>
                  <h5 class="fw-bold font-display text-dark mb-0">Registration Status</h5>
                </div>
                <span class="badge py-2 px-3 fs-6 font-display rounded-pill" id="main-reg-status-badge">
                  🟡 Pending Centre Approval
                </span>
              </div>

              <div class="p-3 rounded-3 border" id="reg-status-body-container" style="background-color: #f8fafc;">
                <p class="mb-2 text-dark fw-semibold fs-6" id="reg-status-title">
                  Your registration has been submitted successfully.
                </p>
                <p class="mb-2 text-secondary small" id="reg-status-desc">
                  The Centre Administrator will review your application shortly. You can already access your profile, payment information and registration details while waiting.
                </p>
                <div id="reg-rejection-reason-box" class="alert alert-danger mb-2 d-none">
                  <strong>Reason for Rejection:</strong> <span id="reg-rejection-reason-text">...</span>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-3" id="reg-status-actions">
                  <!-- Dynamic action buttons e.g. Edit Registration, Upload Documents, Resubmit for Approval -->
                </div>
              </div>
            </div>

            <!-- Hidden backward compatible display anchors -->
            <div class="d-none">
              <span id="student-course-display"></span>
              <span id="student-level-display"></span>
              <span id="student-balance-display"></span>
            </div>

            <!-- Stats row -->
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-3 mb-4">
              <div class="col">
                <div class="card p-3 shadow-sm border-0 h-100">
                  <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-primary-subtle text-primary rounded-3 fs-3"><i class="bi bi-journal-bookmark"></i></div>
                    <div>
                      <span class="small text-muted d-block font-display">Registered Courses</span>
                      <strong class="text-dark d-block" id="stat-registered-courses">1 Course</strong>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col">
                <div class="card p-3 shadow-sm border-0 h-100">
                  <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-success-subtle text-success rounded-3 fs-3"><i class="bi bi-award"></i></div>
                    <div>
                      <span class="small text-muted d-block font-display">Completed Courses</span>
                      <strong class="text-dark d-block" id="stat-completed-courses">0 Courses</strong>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col">
                <div class="card p-3 shadow-sm border-0 h-100">
                  <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-warning-subtle text-warning rounded-3 fs-3"><i class="bi bi-file-earmark-text"></i></div>
                    <div>
                      <span class="small text-muted d-block font-display">Pending Assignments</span>
                      <strong class="text-dark d-block" id="stat-pending-assignments">1 Pending</strong>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col">
                <div class="card p-3 shadow-sm border-0 h-100">
                  <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-info-subtle text-info rounded-3 fs-3"><i class="bi bi-calendar-check"></i></div>
                    <div>
                      <span class="small text-muted d-block font-display">Attendance %</span>
                      <strong class="text-dark d-block" id="stat-attendance-percent">85.7%</strong>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col">
                <div class="card p-3 shadow-sm border-0 h-100">
                  <div class="d-flex align-items-center gap-3">
                    <div class="p-3 bg-danger-subtle text-danger rounded-3 fs-3"><i class="bi bi-wallet2"></i></div>
                    <div>
                      <span class="small text-muted d-block font-display">Payment Status</span>
                      <strong class="text-dark d-block" id="stat-payment-status">PENDING AUDIT</strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Grid: Passport Photo, Timeline & Actions -->
            <div class="row g-4">
              <!-- Left Widget: Passport Profile -->
              <div class="col-xl-4 col-12">
                <div class="card shadow-sm border p-4 text-center">
                  <h6 class="fw-bold text-dark font-display mb-3 text-start"><i class="bi bi-person-circle text-primary me-2"></i> Official Profile Card</h6>
                  
                  <div class="passport-photo-frame position-relative">
                    <img id="student-passport-photo" src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&auto=format&fit=crop&q=80" alt="Student Passport">
                  </div>

                  <h5 class="fw-bold text-dark font-display mb-1" id="profile-fullname">Student Name</h5>
                  <div class="text-muted font-mono small mb-2">ID: <span id="student-id-display">EJ-2026-XXXX</span></div>
                  <span class="badge border badge-status mb-3" id="student-status-badge">Pending</span>

                  <div class="border-top pt-3 text-start">
                    <ul class="list-unstyled d-flex flex-column gap-2 small p-0 mb-0">
                      <li class="d-flex justify-content-between"><span class="text-muted">Academic Center:</span> <strong id="profile-centre">Abuja Hub</strong></li>
                      <li class="d-flex justify-content-between"><span class="text-muted">Assigned Instructor:</span> <strong id="profile-instructor">Engr. Kayode</strong></li>
                      <li class="d-flex justify-content-between"><span class="text-muted">Registration Status:</span> <strong id="profile-reg-status" class="text-primary">Approved</strong></li>
                      <li class="d-flex justify-content-between"><span class="text-muted">Payment Status:</span> <strong id="profile-payment-status" class="text-success">Paid</strong></li>
                      <li class="d-flex justify-content-between"><span class="text-muted">Enrollment Date:</span> <strong id="profile-enrollment-date">Not Set</strong></li>
                      <li class="d-flex justify-content-between"><span class="text-muted">Student Email:</span> <strong class="text-truncate" style="max-width: 170px;" id="student-email-display">email@ex.com</strong></li>
                      <li class="d-flex justify-content-between"><span class="text-muted">Active Phone:</span> <strong id="student-phone-display">+234...</strong></li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- Right Widget: Timeline Stepper -->
              <div class="col-xl-8 col-12">
                <div class="card shadow-sm border p-4">
                  <h6 class="fw-bold text-dark font-display mb-4"><i class="bi bi-activity text-primary me-2"></i> Admission Workflow Stepper</h6>
                  
                  <!-- Responsive vertical / horizontal timeline -->
                  <div class="timeline-stepper" id="admission-timeline-stepper">
                    <div class="timeline-step completed" id="step-submitted">
                      <div class="step-icon"><i class="bi bi-check-lg"></i></div>
                      <span class="step-label text-success">Submitted</span>
                    </div>
                    <div class="timeline-step completed" id="step-review">
                      <div class="step-icon"><i class="bi bi-check-lg"></i></div>
                      <span class="step-label text-success">Pending Review</span>
                    </div>
                    <div class="timeline-step active" id="step-approved">
                      <div class="step-icon"><i class="bi bi-patch-check"></i></div>
                      <span class="step-label text-primary">Approved</span>
                    </div>
                    <div class="timeline-step" id="step-rejected">
                      <div class="step-icon"><i class="bi bi-slash-circle"></i></div>
                      <span class="step-label">Rejected</span>
                    </div>
                    <div class="timeline-step" id="step-completed">
                      <div class="step-icon"><i class="bi bi-check-all"></i></div>
                      <span class="step-label">Completed</span>
                    </div>
                  </div>

                  <!-- Personal Statement displays -->
                  <div class="card bg-light border p-3 mt-4" id="bio-display-card">
                    <h6 class="fw-bold font-display text-dark mb-1"><i class="bi bi-chat-quote-fill me-1 text-primary"></i> Personal Statement</h6>
                    <p class="text-muted small mb-0" id="student-bio-display">Edit your profile to add an exciting personal tech mission statement!</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 2. VIEW: MY PROFILE -->
          <div id="sec-profile" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-3"><i class="bi bi-person-bounding-box me-2 text-primary"></i> Update Bio & Contact Coordinates</h4>
              <p class="text-muted small">Update your records, emergency contacts, profile photo, and security passwords in EJaytech Concepts database securely.</p>
              
              <form id="edit-profile-form" class="mt-3">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Full Name</label>
                    <input type="text" class="form-control" id="edit-fullname" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Phone Number</label>
                    <input type="tel" class="form-control" id="edit-phone" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Gender</label>
                    <select class="form-select" id="edit-gender" required>
                      <option value="Male">Male</option>
                      <option value="Female">Female</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Date of Birth</label>
                    <input type="date" class="form-control" id="edit-dob" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">State of Origin</label>
                    <input type="text" class="form-control" id="edit-state" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Email Address</label>
                    <input type="email" class="form-control" id="edit-email" disabled placeholder="student@example.com">
                  </div>
                  <div class="col-md-12">
                    <label class="form-label fw-semibold small">Physical Address</label>
                    <textarea class="form-control" id="edit-address" rows="2" required></textarea>
                  </div>
                  
                  <!-- New fields: Emergency Contact, Profile Picture, Password -->
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Emergency Contact Name</label>
                    <input type="text" class="form-control" id="edit-emergency-name" placeholder="e.g. Kolawole Adebayo">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Emergency Contact Phone</label>
                    <input type="tel" class="form-control" id="edit-emergency-phone" placeholder="e.g. +234 814...">
                  </div>

                  <div class="col-md-12">
                    <label class="form-label fw-semibold small">Profile Picture (Passport Photograph)</label>
                    <input type="file" class="form-control" id="edit-passport-file" accept="image/*" onchange="uploadPassportPhotoLocal(this)">
                    <p class="text-muted small mt-1 mb-0"><i class="bi bi-info-circle"></i> Selecting an image updates your passport instantly across the dashboard workspace.</p>
                  </div>

                  <div class="col-md-12">
                    <label class="form-label fw-semibold small">Short Personal Bio Statement</label>
                    <textarea class="form-control" id="edit-bio" rows="2" placeholder="Tell our Abuja mentors about your future tech, UI/UX, or graphics design goals..."></textarea>
                  </div>
                </div>

                <div class="text-end mt-4">
                  <button type="submit" class="btn btn-primary-custom px-4" id="edit-profile-sub-btn"><i class="bi bi-save-fill me-2"></i> Save Profile Details</button>
                </div>
              </form>
            </div>
          </div>

          <!-- VIEW: ACADEMIC INFORMATION -->
          <div id="sec-academic" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                  <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-mortarboard-fill text-primary me-2"></i> Academic Information & Program Setup</h4>
                  <p class="text-muted small mb-0">Official enrollment details, study centre workstation, and academic timeline.</p>
                </div>
                <span class="badge bg-primary-subtle text-primary border px-3 py-2 fw-bold" id="academic-status-pill">Active Track</span>
              </div>

              <div class="row g-4 mt-1">
                <div class="col-md-6">
                  <div class="p-3 bg-light border rounded-3 h-100">
                    <span class="text-muted small d-block">Selected Study Centre</span>
                    <h5 class="fw-bold text-dark mt-1 mb-1" id="acad-centre-name">Abuja Garki Hub</h5>
                    <p class="text-muted small mb-0" id="acad-centre-address">Suite B18 Capital Plaza Garki, Abuja</p>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="p-3 bg-light border rounded-3 h-100">
                    <span class="text-muted small d-block">Selected Enrolled Programme</span>
                    <h5 class="fw-bold text-dark mt-1 mb-1" id="acad-prog-name">Software Engineering</h5>
                    <p class="text-muted small mb-0">Full-Stack Vocational & Professional Diploma Track</p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="p-3 border rounded-3">
                    <span class="text-muted small d-block">Course Duration</span>
                    <strong class="text-dark fs-6" id="acad-duration">12 Weeks (3 Months)</strong>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="p-3 border rounded-3">
                    <span class="text-muted small d-block">Mode of Study</span>
                    <strong class="text-dark fs-6" id="acad-mode">Physical Workstation & Practical Lab</strong>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="p-3 border rounded-3">
                    <span class="text-muted small d-block">Registration Date</span>
                    <strong class="text-dark fs-6" id="acad-reg-date">2026-06-18</strong>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="p-3 border rounded-3 bg-primary-subtle text-primary">
                    <span class="text-muted small d-block">Expected Completion Date</span>
                    <strong class="fs-6" id="acad-comp-date">2026-09-18</strong>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="p-3 border rounded-3 bg-success-subtle text-success">
                    <span class="text-muted small d-block">Certification Clearance</span>
                    <strong class="fs-6" id="acad-cert-clearance">Pending Course Completion & Centre Signoff</strong>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- VIEW: DOCUMENTS & VERIFICATION -->
          <div id="sec-documents" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-file-earmark-text-fill text-primary me-2"></i> Documents & Identity Verification</h4>
              <p class="text-muted small mb-4">View and upload replacement documents for Centre Admin review and registration verification.</p>

              <div class="row g-4" id="documents-grid-container">
                <!-- Passport Photo Document Card -->
                <div class="col-md-6">
                  <div class="card border p-3 shadow-sm h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h6 class="fw-bold text-dark mb-0"><i class="bi bi-person-bounding-box text-primary me-1"></i> Passport Photograph</h6>
                      <span class="badge bg-warning-subtle text-warning border" id="doc-status-passport">Pending Verification</span>
                    </div>
                    <p class="text-muted small mb-3">Official headshot photo for your student ID card and transcripts.</p>
                    <div class="mb-3 text-center bg-light p-2 rounded">
                      <img id="doc-preview-passport" src="assets/images/placeholder_profile.png" alt="Passport Preview" style="max-height: 120px; object-fit: contain;">
                    </div>
                    <div class="mt-auto">
                      <input type="file" class="form-control form-control-sm mb-2" id="input-doc-passport" accept="image/*" onchange="uploadStudentDocument('passportPhoto', this)">
                      <span class="text-muted extra-small"><i class="bi bi-info-circle"></i> JPEG or PNG under 3MB.</span>
                    </div>
                  </div>
                </div>

                <!-- ID Card Document Card -->
                <div class="col-md-6">
                  <div class="card border p-3 shadow-sm h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h6 class="fw-bold text-dark mb-0"><i class="bi bi-card-heading text-primary me-1"></i> National ID / Voter's Card / NIN</h6>
                      <span class="badge bg-warning-subtle text-warning border" id="doc-status-idcard">Pending Verification</span>
                    </div>
                    <p class="text-muted small mb-3">Official state-issued identification for registry records.</p>
                    <div class="mb-3 text-center bg-light p-2 rounded">
                      <span class="small text-muted" id="doc-preview-idcard">No ID document file attached yet.</span>
                    </div>
                    <div class="mt-auto">
                      <input type="file" class="form-control form-control-sm mb-2" id="input-doc-idcard" accept="image/*,application/pdf" onchange="uploadStudentDocument('idCard', this)">
                      <span class="text-muted extra-small"><i class="bi bi-info-circle"></i> PDF or image copy.</span>
                    </div>
                  </div>
                </div>

                <!-- Academic Certificates Card -->
                <div class="col-md-6">
                  <div class="card border p-3 shadow-sm h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h6 class="fw-bold text-dark mb-0"><i class="bi bi-award text-primary me-1"></i> Academic Certificates (O'Level / Degree)</h6>
                      <span class="badge bg-warning-subtle text-warning border" id="doc-status-certs">Pending Verification</span>
                    </div>
                    <p class="text-muted small mb-3">Previous educational qualifications or certifications.</p>
                    <div class="mb-3 text-center bg-light p-2 rounded">
                      <span class="small text-muted" id="doc-preview-certs">No certificate file attached yet.</span>
                    </div>
                    <div class="mt-auto">
                      <input type="file" class="form-control form-control-sm mb-2" id="input-doc-certs" accept="image/*,application/pdf" onchange="uploadStudentDocument('certificates', this)">
                      <span class="text-muted extra-small"><i class="bi bi-info-circle"></i> Scanned copy in PDF or JPEG format.</span>
                    </div>
                  </div>
                </div>

                <!-- Admission Documents Card -->
                <div class="col-md-6">
                  <div class="card border p-3 shadow-sm h-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <h6 class="fw-bold text-dark mb-0"><i class="bi bi-file-earmark-check text-primary me-1"></i> Admission & Clearance Forms</h6>
                      <span class="badge bg-warning-subtle text-warning border" id="doc-status-supp">Pending Verification</span>
                    </div>
                    <p class="text-muted small mb-3">Signed acceptance letter, code of conduct, or centre clearance form.</p>
                    <div class="mb-3 text-center bg-light p-2 rounded">
                      <span class="small text-muted" id="doc-preview-supp">No admission form attached yet.</span>
                    </div>
                    <div class="mt-auto">
                      <input type="file" class="form-control form-control-sm mb-2" id="input-doc-supp" accept="image/*,application/pdf" onchange="uploadStudentDocument('supportingDocuments', this)">
                      <span class="text-muted extra-small"><i class="bi bi-info-circle"></i> PDF or image format.</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- VIEW: ANNOUNCEMENTS & NEWS -->
          <div id="sec-announcements" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-megaphone-fill text-primary me-2"></i> Centre Announcements & News Feed</h4>
              <p class="text-muted small mb-4">Stay informed on academic schedules, workstation hub updates, and upcoming tech workshops.</p>

              <div class="d-grid gap-3" id="announcements-container">
                <div class="card border p-3 shadow-sm">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-primary">Centre News</span>
                    <small class="text-muted">Today</small>
                  </div>
                  <h6 class="fw-bold text-dark mb-1">EJaytech Concepts Workstation Hours Extended</h6>
                  <p class="text-secondary small mb-0">Practical lab and workstation ranges at Garki Hub, Abeokuta, and Ibadan are now open Monday - Saturday from 8:00 AM to 6:00 PM for project builds.</p>
                </div>

                <div class="card border p-3 shadow-sm">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-success">Academic Calendar</span>
                    <small class="text-muted">This Week</small>
                  </div>
                  <h6 class="fw-bold text-dark mb-1">Semester Capstone Project Defense Dates Announced</h6>
                  <p class="text-secondary small mb-0">Practical capstone project reviews for all active software, design, and cybersecurity cohorts will take place from September 1st to 5th, 2026.</p>
                </div>

                <div class="card border p-3 shadow-sm">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="badge bg-info text-dark">Upcoming Event</span>
                    <small class="text-muted">August 20, 2026</small>
                  </div>
                  <h6 class="fw-bold text-dark mb-1">Industry Guest Workshop: Building Scalable Full-Stack Apps</h6>
                  <p class="text-secondary small mb-0">Join Senior Engineers for a live masterclass on modern frontend architecture and cloud integrations. Virtual classroom links will be dispatched via inbox.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- 3. VIEW: MY COURSES -->
          <div id="sec-courses" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                <div>
                  <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-journal-bookmark-fill text-primary me-2"></i> Active Course Tracks</h4>
                  <p class="text-muted small mb-0">Review details of registered academic program tracks assigned to you this semester.</p>
                </div>
                <div class="d-flex gap-2 no-print">
                  <button class="btn btn-outline-primary btn-sm" onclick="printRegistrationSlip()"><i class="bi bi-printer-fill me-1"></i> Print Slip</button>
                  <button class="btn btn-primary btn-sm" onclick="printRegistrationSlip()"><i class="bi bi-download me-1"></i> Download PDF</button>
                </div>
              </div>

              <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle small text-start">
                  <thead class="table-dark">
                    <tr>
                      <th>Course Code</th>
                      <th>Course Title</th>
                      <th>Credit Units</th>
                      <th>Semester</th>
                      <th>Status</th>
                      <th>Instructor in Charge</th>
                    </tr>
                  </thead>
                  <tbody id="courses-tbody">
                    <!-- Loaded dynamically -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 4. VIEW: INSTRUCTORS -->
          <div id="sec-instructors" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-people-fill text-primary me-2"></i> Instructor Directory</h4>
              <p class="text-muted small mb-4">Meet your course trainers and system engineering supervisors at your active center hub.</p>
              
              <div class="row g-4" id="instructors-card-container">
                <!-- Dynamically cataloged -->
              </div>
            </div>
          </div>

          <!-- 5. VIEW: TIMETABLE -->
          <div id="sec-timetable" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-calendar3 text-primary me-2"></i> Weekly Academic Timetable</h4>
              <p class="text-muted small mb-4">Timetable schedules for live lecture tracks and practical computer range laboratory sessions.</p>
              
              <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-start small">
                  <thead class="table-primary">
                    <tr>
                      <th>Day</th>
                      <th>Time</th>
                      <th>Course Track</th>
                      <th>Venue</th>
                      <th>Instructor</th>
                    </tr>
                  </thead>
                  <tbody id="timetable-tbody">
                    <!-- Timetable logs loaded -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 6. VIEW: PAYMENTS -->
          <div id="sec-payments" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4 mb-4">
              <h4 class="fw-bold font-display text-dark mb-3"><i class="bi bi-wallet2 text-primary me-2"></i> Financial Payments Portal</h4>
              
              <div class="row g-3 mb-4">
                <div class="col-md-4">
                  <div class="bg-primary-subtle p-3 rounded-3 text-start">
                    <span class="small text-muted d-block">Overall Program Fee</span>
                    <h4 class="fw-bold text-primary mb-0" id="pay-total-fee">₦150,000.00</h4>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="bg-success-subtle p-3 rounded-3 text-start">
                    <span class="small text-muted d-block">Amount Verified Paid</span>
                    <h4 class="fw-bold text-success mb-0" id="pay-amount-paid">₦150,000.00</h4>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="bg-danger-subtle p-3 rounded-3 text-start">
                    <span class="small text-muted d-block">Outstanding Balance</span>
                    <h4 class="fw-bold text-danger mb-0" id="pay-balance-due">₦0.00</h4>
                  </div>
                </div>
              </div>

              <!-- Payment Form Upload -->
              <h5 class="fw-bold font-display mb-3 text-dark">Uplink Payment Receipt Proof</h5>
              <form id="payment-receipt-form" class="bg-light p-3 rounded-3 border mb-4">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Payment Amount (₦)</label>
                    <input type="number" class="form-control" id="pay-input-amount" required placeholder="e.g. 50000">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Payment Reference Number</label>
                    <input type="text" class="form-control" id="pay-input-ref" required placeholder="e.g. TRANS-2026-X">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Bank / Payment Method</label>
                    <select class="form-select" id="pay-input-method" required>
                      <option value="Bank Transfer">Bank Transfer</option>
                      <option value="POS Outlet">POS Outlet</option>
                      <option value="Cash at Hub">Cash at Hub</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Uplink Receipt Snapshot</label>
                    <input type="file" class="form-control" id="pay-input-file">
                  </div>
                </div>
                <div class="text-end mt-3">
                  <button type="submit" class="btn btn-dark px-4"><i class="bi bi-cloud-arrow-up-fill me-1"></i> Submit Payment Records</button>
                </div>
              </form>

              <!-- Payment History table -->
              <h5 class="fw-bold font-display mb-3 text-dark">Tuition Verification logs</h5>
              <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle small text-start">
                  <thead>
                    <tr class="table-dark">
                      <th>Payment Reference</th>
                      <th>Payment Date</th>
                      <th>Amount Paid</th>
                      <th>Status</th>
                      <th class="no-print">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="payments-history-tbody">
                    <!-- payments records loaded -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 7. VIEW: RESULTS -->
          <div id="sec-results" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                <div>
                  <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-award-fill text-primary me-2"></i> Semester Academic Results</h4>
                  <p class="text-muted small mb-0">View grades and score sheets submitted by academic command instructors.</p>
                </div>
                <div class="no-print">
                  <button class="btn btn-outline-primary btn-sm" onclick="printGradesResult()"><i class="bi bi-printer-fill me-1"></i> Print Grade Sheet</button>
                  <button class="btn btn-primary btn-sm" onclick="downloadTranscriptTrigger()"><i class="bi bi-download me-1"></i> Download Transcript</button>
                </div>
              </div>

              <!-- GPA display cards -->
              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <div class="p-3 bg-light border rounded-3 text-center">
                    <span class="small text-muted d-block">Calculated Semester GPA</span>
                    <h3 class="fw-bold text-primary mb-0" id="results-gpa">4.85 / 5.00</h3>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="p-3 bg-light border rounded-3 text-center">
                    <span class="small text-muted d-block">Cumulative CGPA</span>
                    <h3 class="fw-bold text-success mb-0" id="results-cgpa">4.85 / 5.00</h3>
                  </div>
                </div>
              </div>

              <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle small text-start">
                  <thead class="table-dark">
                    <tr>
                      <th>Course Code</th>
                      <th>Course Title</th>
                      <th>Continuous Assessment (30)</th>
                      <th>Exam Score (70)</th>
                      <th>Total Score</th>
                      <th>Grade</th>
                      <th>Remarks</th>
                    </tr>
                  </thead>
                  <tbody id="results-tbody">
                    <!-- Loaded dynamically -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 8. VIEW: ATTENDANCE -->
          <div id="sec-attendance" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-3"><i class="bi bi-calendar-check-fill text-primary me-2"></i> Attendance Tracking Registry</h4>
              
              <!-- Attendance progress details -->
              <div class="row g-3 mb-4 align-items-center">
                <div class="col-md-4">
                  <div class="p-4 bg-light border rounded-3 text-center h-100 d-flex flex-column justify-content-center align-items-center">
                    <span class="small text-muted d-block mb-2">Attendance Percentage</span>
                    <div class="progress w-100 mb-2" style="height: 15px;">
                      <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: 90%" id="attendance-percent-bar">90%</div>
                    </div>
                    <strong class="text-dark fs-5" id="attendance-percent-text">90% Attendance Rate</strong>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="bg-success-subtle p-3 rounded-3 text-start h-100">
                    <span class="small text-muted d-block">Classes Attended</span>
                    <h4 class="fw-bold text-success mb-0" id="attendance-attended-count">12 Lectures</h4>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="bg-danger-subtle p-3 rounded-3 text-start h-100">
                    <span class="small text-muted d-block">Classes Missed</span>
                    <h4 class="fw-bold text-danger mb-0" id="attendance-missed-count">1 Lecture</h4>
                  </div>
                </div>
              </div>

              <h5 class="fw-bold font-display mb-3 text-dark">Log Registry</h5>
              <div class="table-responsive">
                <table class="table table-hover table-bordered text-start small align-middle">
                  <thead class="table-dark">
                    <tr>
                      <th>Session Date</th>
                      <th>Course Track</th>
                      <th>Status Mark</th>
                      <th>Class Hours</th>
                      <th>Instructor Signoff</th>
                    </tr>
                  </thead>
                  <tbody id="attendance-tbody">
                    <!-- Dynamic logs -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 9. VIEW: LEARNING RESOURCES -->
          <div id="sec-resources" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4 mb-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-folder-symlink-fill text-primary me-2"></i> Course Lecture Chapters & Manuals</h4>
              <p class="text-muted small mb-3">Download curriculum sheets and textbook guides assigned by instructors to support practical workstations exercises.</p>
              
              <!-- Search and Filter resources -->
              <div class="row g-3 mb-4">
                <div class="col-md-8">
                  <input type="text" class="form-control" id="resource-search-input" placeholder="Search manuals, guides, videos, assignments..." onkeyup="filterLearningResources()">
                </div>
                <div class="col-md-4">
                  <select class="form-select" id="resource-category-select" onchange="filterLearningResources()">
                    <option value="all">All Category Resources</option>
                    <option value="pdf">PDF Documents</option>
                    <option value="zip">ZIP Exercises / Templates</option>
                  </select>
                </div>
              </div>

              <div class="row g-3" id="materials-list-container">
                <!-- Dynamically populated -->
              </div>
            </div>

            <!-- Upload Assignment Form -->
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-3"><i class="bi bi-cloud-arrow-up-fill me-2 text-primary"></i> Upload Assignment & Project Files</h4>
              <p class="text-muted small">Submit completed wireframe exercises, Photoshop assets exports, or programming project ZIP folders directly to the instructors.</p>
              
              <form id="assignment-upload-form" class="mt-3">
                <div class="p-4 border border-dashed rounded-3 bg-light text-center mb-3 d-grid gap-3" style="border-style: dashed !important; border-width: 2px !important; border-color: var(--color-border) !important;">
                  <div class="fs-1 text-primary"><i class="bi bi-file-earmark-zip"></i></div>
                  <div>
                    <h6 class="fw-bold mb-1 text-dark font-display">Drag and drop file here, or browse</h6>
                    <p class="text-muted small mb-0">Supported formats: PDF, JPEG, PNG, ZIP (Max size: 6MB)</p>
                  </div>
                  <div class="row justify-content-center">
                    <div class="col-sm-8 col-md-6">
                      <input type="file" class="form-control" id="homework-file-ref" required>
                    </div>
                  </div>
                </div>

                <!-- Upload Progress Spinner alerts -->
                <div class="alert alert-info d-none" id="upload-progress-alert">
                  <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                  Executing secure file storage encryption, please hold...
                </div>

                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-muted" id="last-submission-badge">Last upload link: None submitted yet.</span>
                  <button type="submit" class="btn btn-primary-custom" id="upload-sub-btn"><i class="bi bi-cloud-upload-fill me-1"></i> Upload Material File</button>
                </div>
              </form>
            </div>
          </div>

          <!-- 10. VIEW: MESSAGES -->
          <div id="sec-messages" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-chat-dots-fill text-primary me-2"></i> Communications & Messages</h4>
              <p class="text-muted small mb-4">View and respond to notes sent to you directly by Super Admins, Centre Admins, or assigned instructors.</p>
              
              <div class="row g-4">
                <!-- Message Composition Left Side -->
                <div class="col-md-5">
                  <h6 class="fw-bold mb-3 text-dark">Send Inquiry to Portal Admins</h6>
                  <form id="student-msg-form" class="p-3 border rounded-3 bg-light">
                    <div class="mb-3">
                      <label class="form-label fw-semibold small">Message Recipient</label>
                      <select class="form-select" id="student-msg-recipient" required>
                        <option value="Super Admin">Super Admin (Central Desk)</option>
                        <option value="Centre Admin">Centre Admin (Abuja Garki)</option>
                        <option value="Instructor">Course Instructor (Engr. Kayode)</option>
                      </select>
                    </div>
                    <div class="mb-3">
                      <label class="form-label fw-semibold small">Message Text</label>
                      <textarea class="form-control" id="student-msg-text" rows="4" required placeholder="Write details here..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-send-fill me-1"></i> Dispatch Message</button>
                  </form>
                </div>

                <!-- Message History list on Right Side -->
                <div class="col-md-7">
                  <h6 class="fw-bold mb-3 text-dark">Message Inbox Logs</h6>
                  <div class="d-grid gap-3" id="messages-inbox-container" style="max-height: 400px; overflow-y: auto;">
                    <!-- Dynamically populated messages bubbles -->
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- 11. VIEW: NOTIFICATIONS -->
          <div id="sec-notifications" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold font-display text-dark mb-0"><i class="bi bi-bell-fill text-primary me-2"></i> Notification Logs</h4>
                <button class="btn btn-outline-secondary btn-sm" onclick="dismissAllNotifications()"><i class="bi bi-check2-all me-1"></i> Mark All Read</button>
              </div>
              <p class="text-muted small mb-4">Manage alerts, notifications, and holiday reviews logged inside your profile feed.</p>
              
              <div class="d-grid gap-3" id="alerts-inbox-container">
                <!-- Loaded dynamically -->
              </div>
            </div>
          </div>

          <!-- 12. VIEW: SUPPORT -->
          <div id="sec-support" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4 mb-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-question-circle-fill text-primary me-2"></i> Help & Student Support Desk</h4>
              <p class="text-muted small mb-4">Read frequently answered FAQs or file an online support ticket to resolve issues with records, computer hubs, or logins.</p>
              
              <!-- FAQs accordion section -->
              <h5 class="fw-bold font-display text-dark mb-3">Frequently Asked Questions</h5>
              <div class="accordion border rounded-3 overflow-hidden mb-4" id="faq-accordion">
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq-1" aria-expanded="true">
                      How long does admission review verify?
                    </button>
                  </h2>
                  <div id="faq-1" class="accordion-collapse collapse show" data-bs-parent="#faq-accordion">
                    <div class="accordion-body">
                      Registration checklists are reviewed within 24-48 working hours from Garki Plaza central hub. Ensure tuition transfer proofs are verified.
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-2">
                      Can I download my tuition invoices?
                    </button>
                  </h2>
                  <div id="faq-2" class="accordion-collapse collapse" data-bs-parent="#faq-accordion">
                    <div class="accordion-body">
                      Yes! Toggle to the Payments tab inside this portal, find your verified tuition payment rows, and click the Print button to open and download receipts.
                    </div>
                  </div>
                </div>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq-3">
                      Where can I view class timetables?
                    </button>
                  </h2>
                  <div id="faq-3" class="accordion-collapse collapse" data-bs-parent="#faq-accordion">
                    <div class="accordion-body">
                      Check your active timetable schedule days in the Timetable menu panel. Virtual Zoom session links are included within courses.
                    </div>
                  </div>
                </div>
              </div>

              <!-- Submit support Ticket Form -->
              <h5 class="fw-bold font-display text-dark mb-3">Open New Support Ticket</h5>
              <form id="support-ticket-form" class="p-3 border rounded-3 bg-light">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Problem Subject</label>
                    <input type="text" class="form-control" id="ticket-subject" required placeholder="e.g. Cannot download Software syllabus">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold small">Category Issue</label>
                    <select class="form-select" id="ticket-category" required>
                      <option value="Academics">Academics / Curriculum</option>
                      <option value="Finance">Finance / Receipt Issues</option>
                      <option value="Technical">Portal Login / Password Issues</option>
                    </select>
                  </div>
                  <div class="col-12">
                    <label class="form-label fw-semibold small">Explain Issue details</label>
                    <textarea class="form-control" id="ticket-description" rows="3" required placeholder="Provide log description details..."></textarea>
                  </div>
                </div>
                <div class="text-end mt-3">
                  <button type="submit" class="btn btn-primary px-4"><i class="bi bi-ticket-perforated-fill me-1"></i> File Help Ticket</button>
                </div>
              </form>
            </div>
          </div>

          <!-- 13. VIEW: STUDENT SETTINGS -->
          <div id="sec-settings" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-3"><i class="bi bi-gear-wide-connected text-primary me-2"></i> Settings & Portal Preferences</h4>
              
              <div class="list-group border rounded-3 overflow-hidden">
                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                  <div>
                    <h6 class="fw-bold mb-1 text-dark">Portal Interface Theme Mode</h6>
                    <p class="text-muted small mb-0">Toggle dark workspace backdrop layouts for eye-comfort.</p>
                  </div>
                  <div class="form-check form-switch fs-5">
                    <input class="form-check-input" type="checkbox" role="switch" id="theme-switch-toggle" onchange="togglePortalTheme(this)">
                  </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                  <div>
                    <h6 class="fw-bold mb-1 text-dark">Email Notification Prefs</h6>
                    <p class="text-muted small mb-0">Dispatch alert highlights directly to registered inbox.</p>
                  </div>
                  <div class="form-check form-switch fs-5">
                    <input class="form-check-input" type="checkbox" role="switch" checked>
                  </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                  <div>
                    <h6 class="fw-bold mb-1 text-dark">Privacy Profile Settings</h6>
                    <p class="text-muted small mb-0">Allow other classroom cohorts to search your bio profile.</p>
                  </div>
                  <div class="form-check form-switch fs-5">
                    <input class="form-check-input" type="checkbox" role="switch" checked>
                  </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                  <div>
                    <h6 class="fw-bold mb-1 text-dark">Primary Language Selection</h6>
                    <p class="text-muted small mb-0">Toggle portal language context labels.</p>
                  </div>
                  <select class="form-select w-auto" style="min-width: 150px;">
                    <option value="en">English (UK/NG)</option>
                    <option value="fr">French (Marseille)</option>
                  </select>
                </div>
              </div>

              <!-- Change Security Password Card -->
              <div class="card shadow-sm border p-4 mt-4">
                <h5 class="fw-bold font-display text-dark mb-3"><i class="bi bi-shield-lock me-2 text-primary"></i> Change Security Password</h5>
                <form id="change-password-form">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label fw-semibold small">Current Password</label>
                      <input type="password" class="form-control" id="change-current-password" required placeholder="••••••••">
                    </div>
                    <div class="col-md-6">
                      <label class="form-label fw-semibold small">New Security Password</label>
                      <input type="password" class="form-control" id="change-new-password" required minlength="6" placeholder="Min 6 characters">
                    </div>
                  </div>
                  <div class="text-end mt-3">
                    <button type="submit" class="btn btn-primary px-4" id="change-pwd-sub-btn"><i class="bi bi-key-fill me-1"></i> Update Security Password</button>
                  </div>
                </form>
              </div>

            </div>
          </div>

          <!-- 14. VIEW: CERTIFICATES & CLEARANCES -->
          <div id="sec-certificates" class="dashboard-view-module d-none">
            <div class="card shadow-sm border p-4">
              <h4 class="fw-bold font-display text-dark mb-1"><i class="bi bi-patch-check-fill text-success me-2"></i> Academic Certificates & Clearances</h4>
              <p class="text-muted small mb-4">View and download your digital completion certificates and graduation credentials issued by the central registry.</p>
              
              <div id="certificate-status-container">
                <!-- Loaded dynamically based on student programme status -->
              </div>
            </div>
          </div>

        </div>

      </main>
    </div>
  </div>

  <!-- INVOICE/RECEIPT POPUP MODAL -->
  <div class="modal fade" id="receiptPrintModal" tabindex="-1" aria-hidden="true" style="z-index: 1080;">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 no-print">
          <h5 class="modal-title fw-bold font-display text-dark">Official EJaytech Concepts Tuition Invoice</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="branded-receipt" id="printable-receipt-container">
            <div class="text-center mb-4">
              <img src="/assets/images/logo-512.png" alt="EJaytech Logo" style="width: 64px; height: 64px; margin: 0 auto 0.5rem; object-fit: contain;">
              <h4 class="fw-bold font-display text-dark mb-0">EJaytech Concepts</h4>
              <p class="text-muted small mb-0">Abuja Central Suite B18 Capital Plaza Garki Abuja</p>
              <span class="badge bg-success text-white mt-2 px-3 py-2 fw-bold" style="font-size: 0.9rem;"><i class="bi bi-patch-check-fill"></i> VERIFIED PAID</span>
            </div>

            <div class="border-top border-bottom py-3 mb-4">
              <div class="row g-2 small">
                <div class="col-6"><strong>Student Name:</strong> <span id="r-student-name">...</span></div>
                <div class="col-6 text-end"><strong>Date Issued:</strong> <span id="r-date">...</span></div>
                <div class="col-6"><strong>Student ID:</strong> <span id="r-student-id">...</span></div>
                <div class="col-6 text-end"><strong>Reference Number:</strong> <span id="r-ref">...</span></div>
              </div>
            </div>

            <table class="table table-bordered text-start small">
              <thead class="table-dark">
                <tr>
                  <th>Description</th>
                  <th class="text-end">Amount</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Vocational Core Training Syllabus Tuition Fees &mdash; <span id="r-course">...</span> Track</td>
                  <td class="text-end fw-bold" id="r-amount">₦0.00</td>
                </tr>
                <tr class="table-light">
                  <td class="fw-bold text-end">Total Payment Verified:</td>
                  <td class="text-end fw-bold text-success" id="r-total">₦0.00</td>
                </tr>
              </tbody>
            </table>

            <div class="text-center mt-4 small text-muted">
              <p class="mb-0">Thank you for your academic program setup at EJaytech Concepts!</p>
              <p class="font-mono" style="font-size: 0.72rem;">E-Registry Sign-off: Chief Finance Admin Abuja</p>
            </div>
          </div>
        </div>
        <div class="modal-footer no-print border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
          <button type="button" class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer"></i> Print Invoice</button>
        </div>
      </div>
    </div>
  </div>

  <!-- STUDENT REGISTRATION SLIP PRINT MODAL -->
  <div class="modal fade" id="slipPrintModal" tabindex="-1" aria-hidden="true" style="z-index: 1080;">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header border-0 no-print">
          <h5 class="modal-title fw-bold font-display text-dark">Academic Registration Course Slip</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="p-4 border rounded-3 bg-white text-dark" id="printable-slip-container">
