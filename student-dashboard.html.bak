              <div class="col-md-6"><strong>Student ID Code:</strong> <span id="s-student-id">...</span></div>
              <div class="col-md-6"><strong>Registered Program:</strong> <span id="s-program">...</span></div>
              <div class="col-md-6"><strong>Center Desk:</strong> <span id="s-centre">...</span></div>
              <div class="col-md-6"><strong>Enrollment Date:</strong> <span id="s-date">...</span></div>
              <div class="col-md-6"><strong>Registry Status:</strong> <span class="badge bg-success">Active / Fully Registered</span></div>
            </div>

            <table class="table table-bordered text-start small">
              <thead class="table-dark">
                <tr>
                  <th>Course Code</th>
                  <th>Course Title</th>
                  <th>Credit Units</th>
                  <th>Semester</th>
                  <th>Instructor Assigned</th>
                </tr>
              </thead>
