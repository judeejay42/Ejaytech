  <!-- APPLICATION CONFIRM SIGNOUT MODAL -->
  <div class="modal fade" id="signoutConfirmModal" tabindex="-1" aria-hidden="true" style="z-index: 1100;">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
      <div class="modal-content border-0 shadow-lg rounded-4 text-start">
        <div class="modal-header border-0 p-4 pb-0 d-flex flex-column align-items-center text-center">
          <div class="rounded-circle p-3 mb-2 d-inline-flex justify-content-center align-items-center bg-danger-subtle text-danger" style="width: 70px; height: 70px;">
            <i class="bi bi-box-arrow-right text-danger" style="font-size: 2.2rem;"></i>
          </div>
          <h4 class="modal-title fw-bold font-display text-dark mt-2">Sign Out Confirmation</h4>
        </div>
        <div class="modal-body p-4 text-center">
          <p class="text-secondary mb-4 leading-relaxed">
            Are you sure you want to sign out? Your current student session will end.
          </p>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-light border flex-grow-1 py-3 fw-bold font-display" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-danger flex-grow-1 py-3 fw-bold font-display text-white border-0" onclick="confirmLogout()">Logout</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- App Custom Logic Modules -->
  <script type="module" src="js/firebase-config.js"></script>
  <script type="module" src="js/student-auth.js"></script>
  <script type="module" src="student.js"></script>

  <!-- Bootstrap 5 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Custom JS with WhatsApp Float Integration -->
  <script src="js/main.js"></script>

  <!-- Page Dashboard Script -->
  <script type="module">
    import { db, auth } from "./js/firebase-config.js";
    import { protectStudentPage as protectPageAccess, logoutStudentSession, changeStudentPassword } from "./js/student-auth.js";
    import { getStudentProfile, updateStudentProfile, getStudentNotifications, markNotificationAsRead, getCourseMaterials, uploadAssignmentFile } from "./student.js";
    import { sendEmailNotification } from "./js/email-notifier.js";

    // Enforce student session protection
    protectPageAccess();

    let currentStudentData = null;
    let selectedActiveView = "sec-dashboard";
    let signoutModalObj = null;
    let notificationsUnsubscribe = null;

    /**
     * Show UI state for search failures, server errors, authentication anomalies, or connection timeouts
     */
    function showErrorState(title, message, includeContactButton = true) {
      document.getElementById("dash-loading-screen").classList.add("d-none");
      document.getElementById("active-dashboard-grid").classList.add("d-none");
      
      const errorScreen = document.getElementById("dash-error-screen");
      if (errorScreen) {
        errorScreen.classList.remove("d-none");
      }
      
      const errorTitleEl = document.getElementById("dash-error-title");
      if (errorTitleEl) {
        errorTitleEl.textContent = title;
      }
      
      const errorMsgEl = document.getElementById("dash-error-message");
      if (errorMsgEl) {
        errorMsgEl.textContent = message;
      }
      
      const actionsContainer = document.getElementById("dash-error-actions");
      if (actionsContainer) {
        let html = `<button onclick="window.location.reload()" class="btn btn-dark fw-bold px-4 py-2"><i class="bi bi-arrow-clockwise me-2"></i> Refresh Workspace</button>`;
        if (includeContactButton) {
          html += `<a href="mailto:elijahyahuza@gmail.com" class="btn btn-outline-danger fw-bold px-4 py-2 mt-2" id="contact-admin-btn"><i class="bi bi-envelope-fill me-2"></i> Contact Administrator</a>`;
        }
        actionsContainer.innerHTML = html;
      }
    }

    // Direct Initialization
    document.addEventListener("DOMContentLoaded", async () => {
      console.log("[Portal Initialization] Student workspace online.");
      
      const loadingTextEl = document.getElementById("dash-loading-text");
      
      // Initialize clock
      updateLivePortalClock();
      setInterval(updateLivePortalClock, 1000);

      let isDashboardLoaded = false;

      // Requirement 7: Ensure loading spinner stops after max 10 seconds
      const maxLoadingTimeout = setTimeout(() => {
        if (!isDashboardLoaded) {
          console.error("[Timeout Error] Dashboard initialization exceeded 10 seconds.");
          const loadingScreen = document.getElementById("dash-loading-screen");
          if (loadingScreen) loadingScreen.classList.add("d-none");
          showErrorState("Unable to Connect", "Unable to connect to the server. Please try again.", true);
        }
      }, 10000);

      // Requirement 1 & 10: Wait for onAuthStateChanged() before requesting Firestore data
      try {
        if (loadingTextEl) loadingTextEl.textContent = "Authenticating...";

        const processAuthenticatedUser = async (authUser) => {
          try {
            console.log("[Auth State Verified] Authentication state change completed. Auth user:", authUser);

            const sessionUid = sessionStorage.getItem("student_uid");
            const uidToFetch = (authUser && authUser.uid) ? authUser.uid : sessionUid;
            const emailToFetch = authUser ? authUser.email : null;

            if (!uidToFetch && !emailToFetch) {
              console.warn("[Auth State Check] No authenticated user or valid student session found.");
              clearTimeout(maxLoadingTimeout);
              document.getElementById("dash-loading-screen").classList.add("d-none");
              showErrorState("Profile Not Found", "Student profile not found. Please contact your Centre Administrator.", true);
              return;
            }

            if (loadingTextEl) loadingTextEl.textContent = "Fetching student records...";

            // Requirement 2 & 6: Immediately fetch student document from Firestore with try/catch
            let studentDoc = null;
            let firestoreError = null;

            try {
              studentDoc = await getStudentProfile(uidToFetch, emailToFetch);
            } catch (err) {
              firestoreError = err;
              console.error("[Firestore Read Error] Error fetching student profile document from Firestore:", err);
            }

            clearTimeout(maxLoadingTimeout);

            if (firestoreError) {
              // Requirement 5 & 6: If Firestore cannot be reached or network/permission error occurs
              console.error("[Firestore Connection Error]", firestoreError);
              document.getElementById("dash-loading-screen").classList.add("d-none");
              showErrorState("Unable to Connect", "Unable to connect to the server. Please try again.", true);
              return;
            }

            if (!studentDoc) {
              // Requirement 4: If student document does not exist
              console.warn("[Firestore Read] Student profile document does not exist for UID:", uidToFetch);
              document.getElementById("dash-loading-screen").classList.add("d-none");
              showErrorState("Profile Not Found", "Student profile not found. Please contact your Centre Administrator.", true);
              return;
            }

            // Requirement 3: If student document exists -> hide loading spinner and render complete dashboard
            isDashboardLoaded = true;
            document.getElementById("dash-loading-screen").classList.add("d-none");
            await renderStudentDashboardWithData(studentDoc, uidToFetch);

          } catch (innerErr) {
            console.error("[Dashboard Initialization Error]", innerErr);
            clearTimeout(maxLoadingTimeout);
            document.getElementById("dash-loading-screen").classList.add("d-none");
            showErrorState("Unable to Connect", "Unable to connect to the server. Please try again.", true);
          }
        };

        if (auth && typeof auth.onAuthStateChanged === "function") {
          let unsubscribe = auth.onAuthStateChanged((authUser) => {
            if (typeof unsubscribe === "function") {
              try { unsubscribe(); } catch(e) {}
            }
            processAuthenticatedUser(authUser);
          });
        } else {
          const currentUser = (auth && auth.currentUser) ? auth.currentUser : null;
          processAuthenticatedUser(currentUser);
        }

      } catch (authErr) {
        console.error("[Authentication Error]", authErr);
        clearTimeout(maxLoadingTimeout);
        document.getElementById("dash-loading-screen").classList.add("d-none");
        showErrorState("Unable to Connect", "Unable to connect to the server. Please try again.", true);
      }

      // Sidebar view switcher link binding
      const navLinks = document.querySelectorAll("#nav-hub-links .nav-link");
      navLinks.forEach(link => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const target = link.getAttribute("data-target");
          switchView(target);
          if (window.innerWidth < 992) {
            toggleMobileSidebar();
          }
        });
      });

      // Load initial Settings check state
      const isDark = localStorage.getItem("student_theme_dark") === "true";
      document.getElementById("theme-switch-toggle").checked = isDark;
      if (isDark) {
        document.body.classList.add("dark-theme");
      }
    });

    /**
     * Switch view dynamically
     */
    window.switchView = function(targetId) {
      selectedActiveView = targetId;
      
      // Toggle nav active links
      const links = document.querySelectorAll("#nav-hub-links .nav-link");
      links.forEach(l => {
        if (l.getAttribute("data-target") === targetId) {
          l.classList.add("active");
        } else {
          l.classList.remove("active");
        }
      });

      // Show/hide view containers
      const views = document.querySelectorAll(".dashboard-view-module");
      views.forEach(v => {
        if (v.id === targetId) {
          v.classList.remove("d-none");
        } else {
          v.classList.add("d-none");
        }
      });

      // Update Header Breadcrumb Title
      const titles = {
        "sec-dashboard": "Academic Command Center",
        "sec-profile": "Manage Student Profile",
        "sec-academic": "Academic Information & Program Setup",
        "sec-courses": "My Academic Courses",
        "sec-documents": "Documents & Identity Verification",
        "sec-payments": "Financial Payments Portal",
        "sec-announcements": "Announcements & News Feed",
        "sec-instructors": "Assigned Instructors",
        "sec-timetable": "Course Timetables",
        "sec-results": "Semester Results & Grades",
        "sec-certificates": "Academic Certificates & Clearances",
        "sec-attendance": "Attendance Register Logs",
        "sec-resources": "Learning Study Materials",
        "sec-messages": "Hub Communications Desk",
        "sec-notifications": "Notice Alerts Feed",
        "sec-support": "Student Support Center",
        "sec-settings": "Settings & Preferences"
      };
      document.getElementById("navbar-view-title").textContent = titles[targetId] || "Command Workspace";
    };

    /**
     * Open confirmation modal for Sign Out
     */
    window.triggerSignoutModal = function() {
      if (!signoutModalObj) {
        signoutModalObj = new bootstrap.Modal(document.getElementById("signoutConfirmModal"));
      }
      signoutModalObj.show();
    };

    /**
     * Action to execute actual sign-out
     */
    window.confirmLogout = async function() {
      try {
        await logoutStudentSession();
      } catch (err) {
        console.error("Sign out failed:", err);
        sessionStorage.removeItem("student_logged_in");
        sessionStorage.removeItem("student_uid");
        window.location.href = "student.html";
      }
    };

    /**
     * Toggle responsive mobile sidebar slide-out
     */
    window.toggleMobileSidebar = function() {
      const sidebar = document.getElementById("sidebar");
      const backdrop = document.getElementById("sidebar-backdrop");
      sidebar.classList.toggle("show");
      backdrop.classList.toggle("show");
    };

    /**
     * Update live digital clock
     */
    function updateLivePortalClock() {
      const el = document.getElementById("live-portal-clock");
      if (el) {
        const now = new Date();
        const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        el.textContent = `${timeStr} | UTC Center`;
      }
    }

    /**
     * Portal theme mode switch
     */
    window.togglePortalTheme = function(cb) {
      if (cb.checked) {
        document.body.classList.add("dark-theme");
        localStorage.setItem("student_theme_dark", "true");
      } else {
        document.body.classList.remove("dark-theme");
        localStorage.setItem("student_theme_dark", "false");
      }
    };

    /**
     * Save base64 photo locally
     */
    window.uploadPassportPhotoLocal = function(input) {
      const file = input.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          const base64Url = e.target.result;
          document.getElementById("student-passport-photo").src = base64Url;
          
          // Save in mock_student_profile
          if (currentStudentData) {
            currentStudentData.passportPhoto = base64Url;
            localStorage.setItem("mock_student_profile", JSON.stringify(currentStudentData));
            
            // Sync in main students list
            try {
              const listStr = localStorage.getItem("mock_students_list");
              if (listStr) {
                const list = JSON.parse(listStr);
                const idx = list.findIndex(s => s.uid === currentStudentData.uid);
                if (idx !== -1) {
                  list[idx].passportPhoto = base64Url;
                  localStorage.setItem("mock_students_list", JSON.stringify(list));
                }
              }
            } catch (err) {
              console.warn("Failed to sync passport photo:", err);
            }
          }
        };
        reader.readAsDataURL(file);
      }
    };

    /**
     * Helper to fetch Firestore collections safely with 10s timeout, try/catch, and error logging
     */
    async function fetchFirestoreCollectionWithTimeout(collectionName, timeoutMs = 10000) {
      try {
        if (typeof db !== "undefined" && db && typeof db.collection === "function") {
          const fetchPromise = db.collection(collectionName).get();
          const timeoutPromise = new Promise((_, reject) => 
            setTimeout(() => reject(new Error(`Timeout fetching collection "${collectionName}"`)), timeoutMs)
          );
          const snapshot = await Promise.race([fetchPromise, timeoutPromise]);
          if (snapshot && snapshot.docs) {
            const items = [];
            snapshot.forEach(doc => {
              const d = typeof doc.data === "function" ? doc.data() : doc.data;
              if (d) {
                items.push({ id: doc.id, ...d });
              }
            });
            return items;
          }
        }
      } catch (err) {
        console.error(`[Firestore Query Failed] Error querying collection "${collectionName}":`, err);
      }
      return null;
    }

    /**
     * Primary renderer using live/incoming document data
     */
    async function renderStudentDashboardWithData(data, uid) {
      try {
        currentStudentData = data || {};
        
        // Requirement 1, 12, 13: Hide loader immediately, show grid with profile info
        const loadingScreen = document.getElementById("dash-loading-screen");
        const activeGrid = document.getElementById("active-dashboard-grid");
        if (loadingScreen) loadingScreen.classList.add("d-none");
        if (activeGrid) activeGrid.classList.remove("d-none");

        // Display basic variables with robust fallback values
        const fullnameVal = data.fullname || data.fullName || "Student";
        const studentIdVal = data.studentId || "EJ-PENDING";
        const courseVal = data.course || "Software Engineering";
        const emailVal = data.email || "Not Specified";
        const phoneVal = data.phone || "Not Specified";
        const dobVal = data.dob || "Not Specified";
        const bioVal = data.bio || "Enthusiastic EJaytech Concepts student. Write a custom personal mission statement.";
        const centreVal = data.centreId === "ibadan" ? "Ibadan Centre" : data.centreId === "abk" ? "Abeokuta Hub" : "Abuja Garki Hub";

        document.getElementById("student-fullname-display").textContent = fullnameVal;
        document.getElementById("profile-fullname").textContent = fullnameVal;
        document.getElementById("student-id-display").textContent = studentIdVal;
        document.getElementById("student-course-display").textContent = courseVal;
        document.getElementById("student-email-display").textContent = emailVal;
        document.getElementById("student-phone-display").textContent = phoneVal;
        document.getElementById("profile-centre").textContent = centreVal;
        document.getElementById("student-bio-display").textContent = bioVal;
        document.getElementById("user-display-email").textContent = emailVal;
        document.getElementById("navbar-dropdown-name").textContent = fullnameVal;

        const enrollDate = data.createdAt ? new Date(data.createdAt).toLocaleDateString() : "2026-06-18";
        document.getElementById("profile-enrollment-date").textContent = enrollDate;

        // Custom base64 passport image fallback
        if (data.passportPhoto) {
          document.getElementById("student-passport-photo").src = data.passportPhoto;
        } else {
          document.getElementById("student-passport-photo").src = "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&auto=format&fit=crop&q=80";
        }

        // Set initials avatar safely
        let initials = "ST";
        if (fullnameVal && fullnameVal.trim()) {
          const parts = fullnameVal.trim().split(/\s+/).map(n => n ? n[0] : "").filter(Boolean);
          if (parts.length > 0) {
            initials = parts.join("").substring(0, 2).toUpperCase();
          }
        }
        document.getElementById("navbar-avatar-initials").textContent = initials;

        // Dynamic Calculations for stats cards
        const allCourses = JSON.parse(localStorage.getItem("mock_courses") || "[]");
        const matchedCourses = allCourses.filter(c => c.title === courseVal || c.courseName === courseVal);
        const coursesCount = matchedCourses.length;
        document.getElementById("stat-registered-courses").textContent = `${coursesCount} Unit${coursesCount === 1 ? '' : 's'}`;

        const statusLower = (data.status || "approved").toLowerCase();
        const isCompleted = statusLower === "completed";
        document.getElementById("stat-completed-courses").textContent = `${isCompleted ? coursesCount : 0} Unit${(isCompleted ? coursesCount : 0) === 1 ? '' : 's'}`;

        const pendingAssignments = data.lastDocumentSubmitted ? 0 : 1;
        document.getElementById("stat-pending-assignments").textContent = `${pendingAssignments} Pending`;

        let attPercent = "92.5%";
        try {
          const atts = JSON.parse(localStorage.getItem("mock_attendance_individual") || "[]");
          const studentAtt = atts.filter(a => a.studentId === studentIdVal);
          if (studentAtt.length > 0) {
            const present = studentAtt.filter(a => a.status === "Present").length;
            attPercent = ((present / studentAtt.length) * 100).toFixed(1) + "%";
          }
        } catch (e) {
          console.warn("Failed calculating attendance %", e);
        }
        document.getElementById("stat-attendance-percent").textContent = attPercent;

        let payStatusText = "UNDER AUDIT";
        let verifiedPaid = false;
        try {
          const payments = JSON.parse(localStorage.getItem("mock_payments") || "[]");
          const studentPay = payments.filter(p => p.studentId === studentIdVal);
          if (studentPay.length > 0) {
            verifiedPaid = studentPay.some(p => p.status === "Verified" || p.status === "Approved");
            payStatusText = verifiedPaid ? "VERIFIED PAID" : "PENDING AUDIT";
          }
        } catch (e) {
          console.warn("Failed calculating pay status", e);
        }
        document.getElementById("stat-payment-status").textContent = payStatusText;

        // Additional profile tags
        document.getElementById("profile-instructor").textContent = matchedCourses.length > 0 ? matchedCourses[0].instructor : "Engr. Kayode";
        document.getElementById("profile-reg-status").textContent = statusLower === "pending" ? "Pending Review" : statusLower === "rejected" ? "Admission Rejected" : "Fully Approved";
        document.getElementById("profile-reg-status").className = statusLower === "pending" ? "text-warning" : statusLower === "rejected" ? "text-danger" : "text-primary";
        document.getElementById("profile-payment-status").textContent = verifiedPaid ? "Fully Verified" : "Under Audit";
        document.getElementById("profile-payment-status").className = verifiedPaid ? "text-success" : "text-warning";

        // Level & Financial Balance displays computed
        const calculatedBalance = verifiedPaid ? "₦0.00" : "₦15,000.00";
        document.getElementById("student-balance-display").textContent = calculatedBalance;
        document.getElementById("pay-balance-due").textContent = calculatedBalance;

        // Setup form initial state
        document.getElementById("edit-fullname").value = fullnameVal;
        document.getElementById("edit-phone").value = phoneVal;
        document.getElementById("edit-gender").value = data.gender || "Male";
        document.getElementById("edit-dob").value = dobVal;
        document.getElementById("edit-state").value = data.state || "Abuja";
        document.getElementById("edit-address").value = data.address || "Capital Suite, Abuja";
        document.getElementById("edit-bio").value = bioVal;
        document.getElementById("edit-emergency-name").value = data.emergencyName || "";
        document.getElementById("edit-emergency-phone").value = data.emergencyPhone || "";
        document.getElementById("edit-email").value = emailVal;

        // Populate Academic Information View
        const centreAddresses = {
          "abk": "Suite 12 Abeokuta Central Hub, Ogun State",
          "ibadan": "Block 4 Ring Road Tech Hub, Ibadan",
          "abuja": "Suite B18 Capital Plaza Garki, Abuja"
        };
        const centreAddr = centreAddresses[data.centreId] || "Suite B18 Capital Plaza Garki, Abuja";
        if (document.getElementById("acad-centre-name")) document.getElementById("acad-centre-name").textContent = centreVal;
        if (document.getElementById("acad-centre-address")) document.getElementById("acad-centre-address").textContent = centreAddr;
        if (document.getElementById("acad-prog-name")) document.getElementById("acad-prog-name").textContent = courseVal;
        if (document.getElementById("acad-reg-date")) document.getElementById("acad-reg-date").textContent = enrollDate;
        
        // Populate Documents View
        if (data.passportPhoto && document.getElementById("doc-preview-passport")) {
          document.getElementById("doc-preview-passport").src = data.passportPhoto;
        }
        if (data.documents) {
          if (data.documents.idCard && document.getElementById("doc-preview-idcard")) {
            document.getElementById("doc-preview-idcard").textContent = "ID Card Document Attached";
            if (document.getElementById("doc-status-idcard")) {
              document.getElementById("doc-status-idcard").textContent = "Uploaded / In Review";
              document.getElementById("doc-status-idcard").className = "badge bg-info-subtle text-info border";
            }
          }
          if (data.documents.certificates && document.getElementById("doc-preview-certs")) {
            document.getElementById("doc-preview-certs").textContent = "Certificates Document Attached";
            if (document.getElementById("doc-status-certs")) {
              document.getElementById("doc-status-certs").textContent = "Uploaded / In Review";
              document.getElementById("doc-status-certs").className = "badge bg-info-subtle text-info border";
            }
          }
          if (data.documents.supportingDocuments && document.getElementById("doc-preview-supp")) {
            document.getElementById("doc-preview-supp").textContent = "Admission Form Attached";
            if (document.getElementById("doc-status-supp")) {
              document.getElementById("doc-status-supp").textContent = "Uploaded / In Review";
              document.getElementById("doc-status-supp").className = "badge bg-info-subtle text-info border";
            }
          }
        }

        // Handle Admission Stepper and Registration Status Card
        const statusVal = data.status || "pending";
        
        // Update Prominent Registration Status Card
        const regStatusBadge = document.getElementById("main-reg-status-badge");
        const regStatusTitle = document.getElementById("reg-status-title");
        const regStatusDesc = document.getElementById("reg-status-desc");
        const regRejectionBox = document.getElementById("reg-rejection-reason-box");
        const regRejectionText = document.getElementById("reg-rejection-reason-text");
        const regStatusActions = document.getElementById("reg-status-actions");

        if (regStatusBadge && regStatusTitle && regStatusDesc && regStatusActions) {
          regStatusActions.innerHTML = "";
          if (regRejectionBox) regRejectionBox.classList.add("d-none");

          if (statusLower === "pending") {
            regStatusBadge.textContent = "🟡 Pending Centre Approval";
            regStatusBadge.className = "badge bg-warning-subtle text-warning-emphasis border border-warning py-2 px-3 fs-6 font-display rounded-pill";
            regStatusTitle.textContent = "Your registration has been submitted successfully.";
            regStatusDesc.textContent = "The Centre Administrator will review your application shortly. You can already access your profile, payment information and registration details while waiting.";
            regStatusActions.innerHTML = `
              <button class="btn btn-outline-primary btn-sm" onclick="switchView('sec-profile')"><i class="bi bi-person-gear me-1"></i> View Profile</button>
              <button class="btn btn-outline-secondary btn-sm" onclick="switchView('sec-payments')"><i class="bi bi-wallet2 me-1"></i> Payment Info</button>
              <button class="btn btn-outline-info btn-sm" onclick="switchView('sec-documents')"><i class="bi bi-file-earmark-text me-1"></i> Upload/Review Documents</button>
            `;
          } else if (statusLower === "rejected") {
            regStatusBadge.textContent = "🔴 Registration Rejected";
            regStatusBadge.className = "badge bg-danger-subtle text-danger border border-danger py-2 px-3 fs-6 font-display rounded-pill";
            regStatusTitle.textContent = "Your admission application was rejected during centre review.";
            regStatusDesc.textContent = "Application details or uploaded credentials require correction. Please review the reason below, update your details or upload replacement documents, then click Resubmit for Approval.";
            if (regRejectionBox && regRejectionText) {
              regRejectionBox.classList.remove("d-none");
              regRejectionText.textContent = data.rejectionReason || "Credentials or details require verification. Please re-upload documents.";
            }
            regStatusActions.innerHTML = `
              <button class="btn btn-primary btn-sm" onclick="switchView('sec-profile')"><i class="bi bi-pencil-square me-1"></i> Edit Registration</button>
              <button class="btn btn-outline-primary btn-sm" onclick="switchView('sec-documents')"><i class="bi bi-file-earmark-arrow-up me-1"></i> Upload Correct Documents</button>
              <button class="btn btn-success btn-sm" onclick="resubmitRegistrationForApproval()"><i class="bi bi-send-check me-1"></i> Resubmit for Approval</button>
            `;
          } else if (statusLower === "approved" || statusLower === "completed" || statusLower === "active") {
            regStatusBadge.textContent = "🟢 Approved";
            regStatusBadge.className = "badge bg-success-subtle text-success border border-success py-2 px-3 fs-6 font-display rounded-pill";
            regStatusTitle.textContent = "Congratulations! Your registration is approved.";
            regStatusDesc.textContent = "Your registration has been reviewed and approved by the Centre Administrator. You have full access to all academic courses, learning materials, live classes, assignments, and certificates.";
            regStatusActions.innerHTML = `
              <button class="btn btn-success btn-sm" onclick="switchView('sec-courses')"><i class="bi bi-journal-check me-1"></i> Go to Courses</button>
              <button class="btn btn-outline-primary btn-sm" onclick="switchView('sec-resources')"><i class="bi bi-folder-symlink me-1"></i> Learning Materials</button>
            `;
          } else {
            regStatusBadge.textContent = "🟣 Payment Pending";
            regStatusBadge.className = "badge bg-purple-subtle text-purple border py-2 px-3 fs-6 font-display rounded-pill";
            regStatusTitle.textContent = "Tuition Payment Review Pending.";
            regStatusDesc.textContent = "Please upload your payment evidence to complete verification.";
            regStatusActions.innerHTML = `
              <button class="btn btn-primary btn-sm" onclick="switchView('sec-payments')"><i class="bi bi-wallet2 me-1"></i> Upload Payment Evidence</button>
            `;
          }
        }

        // Toggle Academic Feature Locks
        const isApprovedState = (statusLower === "approved" || statusLower === "completed" || statusLower === "active");
        const lockBadges = document.querySelectorAll(".locked-nav-badge");
        lockBadges.forEach(badge => {
          if (isApprovedState) {
            badge.classList.add("d-none");
          } else {
            badge.classList.remove("d-none");
          }
        });

        // Timeline stages selection
        const stepSub = document.getElementById("step-submitted");
        const stepRev = document.getElementById("step-review");
        const stepApp = document.getElementById("step-approved");
        const stepRej = document.getElementById("step-rejected");
        const stepComp = document.getElementById("step-completed");

        if (stepSub && stepRev && stepApp && stepRej && stepComp) {
          stepSub.className = "timeline-step completed";
          stepRev.className = "timeline-step completed";
          stepApp.className = "timeline-step";
          stepRej.className = "timeline-step d-none";
          stepComp.className = "timeline-step";

          if (statusLower === "pending") {
            document.getElementById("quick-admission-badge").textContent = "Pending Review";
            document.getElementById("quick-admission-badge").className = "badge bg-warning-subtle text-warning border py-2 px-3 fw-bold rounded-pill";
            stepRev.className = "timeline-step active";
          } else if (statusLower === "approved") {
            document.getElementById("quick-admission-badge").textContent = "Admission Approved";
            document.getElementById("quick-admission-badge").className = "badge bg-success-subtle text-success border py-2 px-3 fw-bold rounded-pill";
            stepApp.className = "timeline-step completed";
            stepComp.className = "timeline-step active";
          } else if (statusLower === "rejected") {
            document.getElementById("quick-admission-badge").textContent = "Admission Rejected";
            document.getElementById("quick-admission-badge").className = "badge bg-danger-subtle text-danger border py-2 px-3 fw-bold rounded-pill";
            stepRej.classList.remove("d-none");
            stepRej.className = "timeline-step active";
            stepApp.className = "timeline-step d-none";
          } else if (statusLower === "completed" || statusLower === "active") {
            document.getElementById("quick-admission-badge").textContent = "Registration Completed";
            document.getElementById("quick-admission-badge").className = "badge bg-success-subtle text-success border py-2 px-3 fw-bold rounded-pill";
            stepApp.className = "timeline-step completed";
            stepComp.className = "timeline-step completed";
          }
        }

        // Homework submit log badge
        if (data.lastDocumentSubmitted) {
          document.getElementById("last-submission-badge").innerHTML = `
            <a href="${data.lastDocumentSubmitted}" target="_blank" class="text-success fw-bold text-decoration-none">
              <i class="bi bi-check-circle-fill me-1"></i> View Submitted Homework File <i class="bi bi-box-arrow-up-right small"></i>
            </a>`;
        } else {
          document.getElementById("last-submission-badge").innerHTML = "";
        }

        // Requirement 9, 10, 11: Load each dashboard widget independently without blocking or stopping dashboard
        loadCoursesList(courseVal).catch(err => console.error("[Widget Query Failed] loadCoursesList:", err));
        loadInstructorsList(courseVal).catch(err => console.error("[Widget Query Failed] loadInstructorsList:", err));
        loadTimetableList(courseVal).catch(err => console.error("[Widget Query Failed] loadTimetableList:", err));
        loadPaymentsList(studentIdVal).catch(err => console.error("[Widget Query Failed] loadPaymentsList:", err));
        loadResultsList(studentIdVal).catch(err => console.error("[Widget Query Failed] loadResultsList:", err));
        loadAttendanceList(courseVal).catch(err => console.error("[Widget Query Failed] loadAttendanceList:", err));
        loadLearningMaterials(courseVal).catch(err => console.error("[Widget Query Failed] loadLearningMaterials:", err));
        loadMessagesList().catch(err => console.error("[Widget Query Failed] loadMessagesList:", err));
        loadCertificatesList().catch(err => console.error("[Widget Query Failed] loadCertificatesList:", err));

        // Subscribe to real-time notifications
        if (!notificationsUnsubscribe && typeof db !== "undefined" && db && typeof db.collection === "function") {
          try {
            notificationsUnsubscribe = db.collection("notifications")
              .onSnapshot(async () => {
                await loadDashboardNotifications();
              }, (err) => {
                console.error("Notifications socket subscription error:", err);
              });
          } catch (subErr) {
            console.error("Failed to subscribe to notifications:", subErr);
            loadDashboardNotifications().catch(err => console.error("[Widget Query Failed] loadDashboardNotifications:", err));
          }
        } else {
          loadDashboardNotifications().catch(err => console.error("[Widget Query Failed] loadDashboardNotifications:", err));
        }

      } catch (err) {
        console.error("Fetch profile failed:", err);
      }
    }

    /**
     * Load Registered Courses datatable
     */
    async function loadCoursesList(courseName) {
      const tbody = document.getElementById("courses-tbody");
      const slipTbody = document.getElementById("slip-courses-tbody");
      if (!tbody || !slipTbody) return;

      tbody.innerHTML = "";
      slipTbody.innerHTML = "";

      let matched = [];
      try {
        const firestoreCourses = await fetchFirestoreCollectionWithTimeout("courses", 10000);
        if (firestoreCourses && Array.isArray(firestoreCourses) && firestoreCourses.length > 0) {
          matched = firestoreCourses.filter(c => 
            (c.title && c.title.toLowerCase().includes((courseName || "").toLowerCase())) ||
            (c.courseName && c.courseName.toLowerCase().includes((courseName || "").toLowerCase())) ||
            (c.course && c.course.toLowerCase().includes((courseName || "").toLowerCase()))
          );
        } else {
          const allCourses = JSON.parse(localStorage.getItem("mock_courses") || "[]");
          matched = allCourses.filter(c => c.title === courseName || c.courseName === courseName || c.course === courseName);
        }
      } catch (err) {
        console.error("[Firestore Query Failed] loadCoursesList error:", err);
      }

      // Requirement 5: If Courses collection is empty: Display "No courses assigned yet."
      if (!matched || matched.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted">No courses assigned yet.</td></tr>`;
        slipTbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-muted">No courses assigned yet.</td></tr>`;
        return;
      }

      matched.forEach((c) => {
        const code = c.code || (c.id === "course-1" ? "SEN-201" : c.id === "course-2" ? "GRD-101" : "CYB-301");
        const units = c.units || (c.id === "course-1" ? 4 : c.id === "course-2" ? 3 : 4);
        const title = c.title || c.courseName || courseName;
        const instructor = c.instructor || "Assigned Instructor";
        
        tbody.innerHTML += `
          <tr>
            <td><code class="fw-bold">${code}</code></td>
            <td><span class="fw-semibold text-dark">${title}</span></td>
            <td>${units} Units</td>
            <td>1st Semester</td>
            <td><span class="badge bg-success-subtle text-success border">Active</span></td>
            <td><code>${instructor}</code></td>
          </tr>
        `;

        slipTbody.innerHTML += `
          <tr>
            <td><code>${code}</code></td>
            <td><strong>${title}</strong></td>
            <td>${units} Units</td>
            <td>1st Semester</td>
            <td>${instructor}</td>
          </tr>
        `;
      });
    }

    /**
     * Print academic slip trigger
     */
    window.printRegistrationSlip = function() {
      if (!currentStudentData) return;
      document.getElementById("s-fullname").textContent = currentStudentData.fullname || currentStudentData.fullName || "Student Name";
      document.getElementById("s-student-id").textContent = currentStudentData.studentId || "EJ-PENDING";
      document.getElementById("s-program").textContent = currentStudentData.course || "Software Track";
      document.getElementById("s-centre").textContent = currentStudentData.centreId === "ibadan" ? "Ibadan Centre" : "Abuja Hub";
      document.getElementById("s-date").textContent = currentStudentData.createdAt ? new Date(currentStudentData.createdAt).toLocaleDateString() : "2026-06-18";

      const modal = new bootstrap.Modal(document.getElementById("slipPrintModal"));
      modal.show();
    };

    /**
     * Load Instructor directory cards
     */
    async function loadInstructorsList(courseName) {
      const container = document.getElementById("instructors-card-container");
      if (!container) return;
      container.innerHTML = "";

      let filtered = [];
      try {
        let instructors = await fetchFirestoreCollectionWithTimeout("instructors", 10000);
        if (!instructors || !Array.isArray(instructors) || instructors.length === 0) {
          instructors = JSON.parse(localStorage.getItem("mock_instructors") || "[]");
        }

        const studentCentreId = (currentStudentData && currentStudentData.centreId || "abuja").toLowerCase();
        
        filtered = instructors.filter(inst => {
          const assigned = (inst.assignedCourses || inst.course || "").toLowerCase();
          const matchesCourse = !courseName || assigned.includes((courseName || "").toLowerCase());
          const instCentre = (inst.centre || "").toLowerCase();
          const matchesCentre = instCentre.includes(studentCentreId) || 
                                (studentCentreId === "abuja" && (instCentre.includes("abuja") || instCentre.includes("garki") || instCentre.includes("hub"))) ||
                                (studentCentreId === "abk" && instCentre.includes("abk")) ||
                                (studentCentreId === "ibadan" && instCentre.includes("ibadan"));
          return matchesCourse && matchesCentre;
        });
      } catch (err) {
        console.error("[Firestore Query Failed] loadInstructorsList error:", err);
      }

      // Requirement 6: If Instructor collection is empty: Display "Instructor will be assigned shortly."
      if (!filtered || filtered.length === 0) {
        container.innerHTML = `
          <div class="col-12 text-center py-4 text-muted border rounded-3 bg-light">
            <i class="bi bi-people fs-2 d-block mb-2 text-secondary"></i>
            Instructor will be assigned shortly.
          </div>`;
        return;
      }

      filtered.forEach(inst => {
        container.innerHTML += `
          <div class="col-md-6 col-12">
            <div class="card h-100 border p-3">
              <div class="d-flex align-items-center gap-3">
                <img src="${inst.profilePhoto || 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&auto=format&fit=crop&q=80'}" class="rounded-circle border" style="width: 72px; height: 72px; object-fit: cover;">
                <div class="text-start">
                  <h6 class="fw-bold text-dark font-display mb-1">${inst.name || 'Instructor'}</h6>
                  <p class="text-primary small fw-semibold mb-1" style="font-size: 0.85rem;">${inst.department || 'Academic Department'}</p>
                  <span class="badge bg-light text-muted border small">${inst.centre || 'Training Centre'}</span>
                </div>
              </div>
              <div class="border-top mt-3 pt-2 text-start small">
                <p class="mb-1"><i class="bi bi-calendar2-week text-primary me-2"></i><strong>Office Hours:</strong> ${inst.officeHours || 'Mon - Fri, 09:00 AM - 04:00 PM'}</p>
                <p class="mb-0"><i class="bi bi-envelope-at text-danger me-2"></i><strong>Email:</strong> <a href="mailto:${inst.email}">${inst.email || 'instructor@ejaytech.com'}</a></p>
                ${inst.phone ? `<p class="mb-0 mt-1"><i class="bi bi-telephone-fill text-success me-2"></i><strong>Phone:</strong> ${inst.phone}</p>` : ''}
              </div>
            </div>
          </div>
        `;
      });
    }

    /**
     * Load Course timetables
     */
    async function loadTimetableList(courseName) {
      const tbody = document.getElementById("timetable-tbody");
      if (!tbody) return;
      tbody.innerHTML = "";

      let matched = [];
      try {
        let timetable = await fetchFirestoreCollectionWithTimeout("timetable", 10000);
        if (!timetable || !Array.isArray(timetable) || timetable.length === 0) {
          timetable = JSON.parse(localStorage.getItem("mock_timetable") || "[]");
        }

        const studentCentreId = (currentStudentData && currentStudentData.centreId || "abuja").toLowerCase();
        
        matched = timetable.filter(t => {
          const matchesCourse = (t.course || "").toLowerCase().includes((courseName || "").toLowerCase());
          const venue = (t.venue || "").toLowerCase();
          const matchesCentre = venue.includes(studentCentreId) || 
                                venue.includes("virtual") || 
                                (studentCentreId === "abuja" && (venue.includes("abuja") || venue.includes("garki"))) ||
                                (studentCentreId === "abk" && venue.includes("abk")) ||
                                (studentCentreId === "ibadan" && venue.includes("ibadan"));
          return matchesCourse && matchesCentre;
        });
      } catch (err) {
        console.error("[Firestore Query Failed] loadTimetableList error:", err);
      }

      if (!matched || matched.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-muted">No timetable sessions loaded for: ${courseName}</td></tr>`;
        return;
      }

      matched.forEach(t => {
        tbody.innerHTML += `
          <tr>
            <td><strong>${t.day}</strong></td>
            <td><span class="badge bg-light text-dark border font-mono">${t.time}</span></td>
            <td><span class="fw-semibold text-dark">${t.course}</span></td>
            <td><i class="bi bi-geo-alt-fill text-danger me-1"></i> ${t.venue}</td>
            <td><code>${t.instructor}</code></td>
          </tr>
        `;
      });
    }

    /**
     * Load Tuition Payments history
     */
    async function loadPaymentsList(studentId) {
      const tbody = document.getElementById("payments-history-tbody");
      if (!tbody) return;
      tbody.innerHTML = "";

      let matched = [];
      try {
        let allPayments = await fetchFirestoreCollectionWithTimeout("payments", 10000);
        if (!allPayments || !Array.isArray(allPayments) || allPayments.length === 0) {
          allPayments = JSON.parse(localStorage.getItem("mock_payments") || "[]");
        }
        matched = allPayments.filter(p => p.studentId === studentId || p.uid === studentId);
      } catch (err) {
        console.error("[Firestore Query Failed] loadPaymentsList error:", err);
      }

      // Compute visual cards totals
      let totalPaidVal = 0;
      let programFeeVal = 150000;

      matched.forEach(p => {
        const statusStr = (p.status || "").toLowerCase();
        if (statusStr === "verified" || statusStr === "approved") {
          totalPaidVal += Number(p.amount || 0);
        }
      });

      if (currentStudentData && currentStudentData.course === "Graphic Design") {
        programFeeVal = 85000;
      } else if (currentStudentData && currentStudentData.course === "Cybersecurity Basics") {
        programFeeVal = 120000;
      }

      if (document.getElementById("pay-total-fee")) document.getElementById("pay-total-fee").textContent = `₦${programFeeVal.toLocaleString()}.00`;
      if (document.getElementById("pay-amount-paid")) document.getElementById("pay-amount-paid").textContent = `₦${totalPaidVal.toLocaleString()}.00`;
      
      const balanceVal = Math.max(0, programFeeVal - totalPaidVal);
      if (document.getElementById("pay-balance-due")) document.getElementById("pay-balance-due").textContent = `₦${balanceVal.toLocaleString()}.00`;
      if (document.getElementById("student-balance-display")) document.getElementById("student-balance-display").textContent = `₦${balanceVal.toLocaleString()}.00`;

      // Requirement 7: If Payment collection is empty: Display "No payment record available."
      if (!matched || matched.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-muted">No payment record available.</td></tr>`;
        return;
      }

      matched.forEach(p => {
        const statusStr = (p.status || "").toLowerCase();
        const isVerified = statusStr === "verified" || statusStr === "approved";
        const statusBadge = isVerified ? 
          `<span class="badge bg-success-subtle text-success border">Verified</span>` : 
          `<span class="badge bg-warning-subtle text-warning border">Pending Verification</span>`;

        const printBtn = isVerified ? 
          `<button class="btn btn-outline-dark btn-sm py-1 font-display" onclick="printReceipt('${p.id}')"><i class="bi bi-printer-fill me-1"></i> Receipt</button>` : '';

        tbody.innerHTML += `
          <tr>
            <td><code class="fw-bold">${p.referenceNumber || p.id}</code></td>
            <td>${p.paymentDate || (p.createdAt ? new Date(p.createdAt).toLocaleDateString() : 'N/A')}</td>
            <td class="fw-bold">₦${Number(p.amount || 0).toLocaleString()}.00</td>
            <td>${statusBadge}</td>
            <td class="no-print">${printBtn}</td>
          </tr>
        `;
      });
    }

    /**
     * Interactive receipt popups
     */
    window.printReceipt = function(paymentId) {
      const allPayments = JSON.parse(localStorage.getItem("mock_payments") || "[]");
      const payObj = allPayments.find(p => p.id === paymentId);
      if (!payObj) return;

      document.getElementById("r-student-name").textContent = payObj.studentName;
      document.getElementById("r-student-id").textContent = payObj.studentId;
      document.getElementById("r-date").textContent = payObj.paymentDate || new Date(payObj.createdAt).toLocaleDateString();
      document.getElementById("r-ref").textContent = payObj.referenceNumber;
      document.getElementById("r-course").textContent = payObj.course;
      document.getElementById("r-amount").textContent = `₦${Number(payObj.amount).toLocaleString()}.00`;
      document.getElementById("r-total").textContent = `₦${Number(payObj.amount).toLocaleString()}.00`;

      const modal = new bootstrap.Modal(document.getElementById("receiptPrintModal"));
      modal.show();
    };

    /**
     * Submit new tuition receipt form
     */
    document.getElementById("payment-receipt-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const amount = document.getElementById("pay-input-amount").value;
      const ref = document.getElementById("pay-input-ref").value;
      const method = document.getElementById("pay-input-method").value;

      try {
        const allPayments = JSON.parse(localStorage.getItem("mock_payments") || "[]");
        const newPay = {
          id: "PAY-" + Date.now(),
          studentName: currentStudentData.fullname || currentStudentData.fullName,
          studentId: currentStudentData.studentId,
          course: currentStudentData.course,
          amount: Number(amount),
          paymentMethod: method,
          paymentDate: new Date().toISOString().split('T')[0],
          referenceNumber: ref,
          proofOfPayment: "assets/images/placeholder_document.pdf",
          status: "Pending",
          centreId: currentStudentData.centreId || "abk",
          createdAt: new Date().toISOString()
        };

        allPayments.unshift(newPay);
        localStorage.setItem("mock_payments", JSON.stringify(allPayments));

        // Dispatch Payment Submission Received Email
        try {
          if (currentStudentData && currentStudentData.email) {
            await sendEmailNotification("payment_submission", currentStudentData.email, {
              studentName: currentStudentData.fullname || currentStudentData.fullName,
              amount: Number(amount).toLocaleString(),
              referenceNumber: ref,
              course: currentStudentData.course
            });
          }
        } catch (emailErr) {
          console.warn("Payment submission email notification error:", emailErr);
        }
        
        alert("Success! Receipt proof submitted. Academic finance desk will verify soon.");
        document.getElementById("payment-receipt-form").reset();
        await loadPaymentsList(currentStudentData.studentId);
      } catch (err) {
        alert("Failed to record payment: " + err.message);
      }
    });

    /**
     * Load Academic Semester Results
     */
    async function loadResultsList(studentId) {
      const tbody = document.getElementById("results-tbody");
      if (!tbody) return;
      tbody.innerHTML = "";

      let matched = [];
      try {
        let allGrades = await fetchFirestoreCollectionWithTimeout("grades", 10000);
        if (!allGrades || !Array.isArray(allGrades) || allGrades.length === 0) {
          allGrades = JSON.parse(localStorage.getItem("mock_grades") || "[]");
        }
        matched = allGrades.filter(g => g.studentId === studentId || g.uid === studentId);
      } catch (err) {
        console.error("[Firestore Query Failed] loadResultsList error:", err);
      }

      if (!matched || matched.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-muted">Awaiting exam score grading cards uploads.</td></tr>`;
        if (document.getElementById("results-gpa")) document.getElementById("results-gpa").textContent = "N/A";
        if (document.getElementById("results-cgpa")) document.getElementById("results-cgpa").textContent = "N/A";
        return;
      }

      matched.forEach(g => {
        tbody.innerHTML += `
          <tr>
            <td><code class="fw-bold">${g.courseCode || 'SEN-201'}</code></td>
            <td><span class="fw-semibold text-dark">${g.course || 'Course Track'}</span></td>
            <td class="fw-bold font-mono">${g.testScore || 0} / 30</td>
            <td class="fw-bold font-mono">${g.examScore || 0} / 70</td>
            <td class="fw-bold font-mono text-primary">${g.totalScore || (Number(g.testScore || 0) + Number(g.examScore || 0))}</td>
            <td><span class="badge bg-primary px-3 py-1 font-mono">${g.grade || 'N/A'}</span></td>
            <td><em class="text-muted small">${g.remarks || ''}</em></td>
          </tr>
        `;
      });
    }

    /**
     * Print statement of results slip
     */
    window.printGradesResult = function() {
      window.print();
    };

    /**
     * Download transcript placeholder trigger
     */
    window.downloadTranscriptTrigger = function() {
      alert("Academic Transcript request submitted to registry center. The digital copy will release upon graduation clearance.");
    };

    /**
     * Load Attendance records
     */
    async function loadAttendanceList(courseName) {
      const tbody = document.getElementById("attendance-tbody");
      if (!tbody) return;
      tbody.innerHTML = "";

      let matched = [];
      try {
        let list = await fetchFirestoreCollectionWithTimeout("attendance", 10000);
        if (!list || !Array.isArray(list) || list.length === 0) {
          list = JSON.parse(localStorage.getItem("mock_attendance_individual") || "[]");
        }
        const studentId = currentStudentData ? currentStudentData.studentId : null;
        matched = list.filter(a => {
          const matchCourse = (a.course || "").toLowerCase().includes((courseName || "").toLowerCase());
          const matchStudent = !studentId || a.studentId === studentId || a.studentId === "all";
          return matchCourse && matchStudent;
        });
      } catch (err) {
        console.error("[Firestore Query Failed] loadAttendanceList error:", err);
      }

      let presentCount = 0;
      matched.forEach(a => {
        if ((a.status || "").toLowerCase() === "present") presentCount++;
      });

      const total = matched.length;
      const missed = total - presentCount;
      const pct = total > 0 ? Math.round((presentCount / total) * 100) : 100;

      if (document.getElementById("attendance-percent-bar")) {
        document.getElementById("attendance-percent-bar").style.width = `${pct}%`;
        document.getElementById("attendance-percent-bar").textContent = `${pct}%`;
      }
      if (document.getElementById("attendance-percent-text")) document.getElementById("attendance-percent-text").textContent = `${pct}% Attendance Rate`;
      if (document.getElementById("attendance-attended-count")) document.getElementById("attendance-attended-count").textContent = `${presentCount} Lectures`;
      if (document.getElementById("attendance-missed-count")) document.getElementById("attendance-missed-count").textContent = `${missed} Lecture${missed !== 1 ? 's' : ''}`;

      // Requirement 8: If Attendance collection is empty: Display "Attendance has not started."
      if (!matched || matched.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-muted">Attendance has not started.</td></tr>`;
        return;
      }

      matched.forEach(a => {
        const markBadge = (a.status || "").toLowerCase() === "present" ? 
          `<span class="badge bg-success-subtle text-success border px-2 py-1"><i class="bi bi-patch-check-fill"></i> Present</span>` :
          `<span class="badge bg-danger-subtle text-danger border px-2 py-1"><i class="bi bi-slash-circle-fill"></i> Absent</span>`;

        tbody.innerHTML += `
          <tr>
            <td><strong>${a.date || 'N/A'}</strong></td>
            <td>${a.course || courseName}</td>
            <td>${markBadge}</td>
            <td>${a.duration || '3 Hours'}</td>
            <td><code>${a.instructor || 'Instructor'}</code></td>
          </tr>
        `;
      });
    }

    /**
     * Load Learning Materials files list
     */
    async function loadLearningMaterials(courseName) {
      const container = document.getElementById("materials-list-container");
      container.innerHTML = "";

      const list = await getCourseMaterials(courseName);

      if (list.length === 0) {
        container.innerHTML = `
          <div class="col-12 text-center py-4 text-muted border rounded-3 bg-light">
            <i class="bi bi-journal-x fs-2 d-block mb-2 text-secondary"></i>
            No study manuals or video files cataloged for: "${courseName}".
          </div>`;
        return;
      }

      renderMaterialsCards(list);
    }

    function renderMaterialsCards(list) {
      const container = document.getElementById("materials-list-container");
      container.innerHTML = "";
      
      list.forEach(mat => {
        const fileIcon = mat.fileType === "zip" ? 
          '<div class="fs-1 text-warning"><i class="bi bi-file-earmark-zip-fill"></i></div>' : 
          '<div class="fs-1 text-danger"><i class="bi bi-file-earmark-pdf-fill"></i></div>';

        container.innerHTML += `
          <div class="col-md-6 col-12 resource-card-item" data-title="${mat.title.toLowerCase()}" data-type="${mat.fileType}">
            <div class="p-3 border rounded-3 bg-light d-flex align-items-center justify-content-between h-100">
              <div class="d-flex align-items-center gap-3">
                ${fileIcon}
                <div class="text-start">
                  <h6 class="fw-bold mb-1 text-dark" style="font-size: 0.92rem;">${mat.title}</h6>
                  <p class="text-muted small mb-0">${mat.description || "Course materials guide."} &bull; <span class="font-mono text-dark">${mat.fileSize || '3.5 MB'}</span></p>
                </div>
              </div>
              <a href="${mat.filePath || '#'}" target="_blank" class="btn btn-outline-primary btn-sm"><i class="bi bi-download"></i></a>
            </div>
          </div>
        `;
      });
    }

    /**
     * Filter materials search
     */
    window.filterLearningResources = function() {
      const query = document.getElementById("resource-search-input").value.toLowerCase();
      const type = document.getElementById("resource-category-select").value;
      const cards = document.querySelectorAll(".resource-card-item");

      cards.forEach(c => {
        const title = c.getAttribute("data-title");
        const cardType = c.getAttribute("data-type");

        const matchesQuery = title.includes(query);
        const matchesType = type === "all" || cardType === type;

        if (matchesQuery && matchesType) {
          c.classList.remove("d-none");
        } else {
          c.classList.add("d-none");
        }
      });
    };

    /**
     * Load notices
     */
    async function loadDashboardNotifications() {
      const container = document.getElementById("alerts-inbox-container");
      const badgeCount = document.getElementById("notif-badge-pill");

      const studentId = currentStudentData ? currentStudentData.studentId : "EJ-2026-9999";
      const list = await getStudentNotifications(studentId);
      
      const unreadCount = list.filter(n => n.status === "unread" || n.read === false).length;
      badgeCount.className = unreadCount > 0 ? "badge bg-danger ms-auto rounded-pill" : "badge bg-secondary ms-auto rounded-pill";
      badgeCount.textContent = unreadCount;

      if (list.length === 0) {
        container.innerHTML = `
          <div class="text-center py-4 text-muted border rounded-3 bg-light p-3">
            No notification logs.
          </div>`;
        return;
      }

      container.innerHTML = "";
      list.forEach(notif => {
        const isUnread = notif.status === "unread" || notif.read === false;
        container.innerHTML += `
          <div class="p-3 rounded-3 border text-start ${isUnread ? 'border-primary bg-primary-subtle' : 'bg-light'}">
            <div class="d-flex justify-content-between align-items-start">
              <h6 class="fw-bold text-dark mb-1 font-display">${notif.title}</h6>
              <span class="small font-mono text-muted text-end" style="font-size: 0.75rem;">${new Date(notif.createdAt).toLocaleDateString()}</span>
            </div>
            <p class="text-muted mb-2 small">${notif.message}</p>
            ${isUnread ? `
              <button onclick="dismissNotification('${notif.id}')" class="btn btn-link p-0 text-primary fw-bold text-decoration-none small" style="font-size: 0.8rem;">
                <i class="bi bi-eye-fill me-1"></i> Dismiss &amp; Mark as Read
              </button>
            ` : `<span class="text-muted small"><i class="bi bi-check2-all"></i> Read Archive</span>`}
          </div>
        `;
      });
    }

    window.dismissNotification = async function(id) {
      await markNotificationAsRead(id);
      await loadDashboardNotifications();
    };

    window.dismissAllNotifications = async function() {
      const list = await getStudentNotifications(currentStudentData.studentId);
      for (let n of list) {
        if (n.status === "unread" || n.read === false) {
          await markNotificationAsRead(n.id);
        }
      }
      await loadDashboardNotifications();
    };

    /**
     * Communications & Messages inbox panel logs
     */
    async function loadMessagesList() {
      const container = document.getElementById("messages-inbox-container");
      const badge = document.getElementById("messages-unseen-badge");
      if (!container) return;
      container.innerHTML = "";

      let msgs = [];
      try {
        let firestoreMsgs = await fetchFirestoreCollectionWithTimeout("messages", 10000);
        if (!firestoreMsgs || !Array.isArray(firestoreMsgs) || firestoreMsgs.length === 0) {
          msgs = JSON.parse(localStorage.getItem("mock_messages") || "[]");
        } else {
          msgs = firestoreMsgs;
        }
      } catch (err) {
        console.error("[Firestore Query Failed] loadMessagesList error:", err);
      }

      if (!msgs || msgs.length === 0) {
        container.innerHTML = `
          <div class="text-center py-4 text-muted border rounded-3 bg-light p-3">
            No communications loaded in thread.
          </div>`;
        if (badge) badge.style.display = "none";
        return;
      }

      if (badge) {
        badge.style.display = "inline-block";
        badge.textContent = msgs.length;
      }

      msgs.forEach(m => {
        container.innerHTML += `
          <div class="p-3 border rounded-3 bg-white text-start shadow-sm mb-2">
            <div class="d-flex align-items-center gap-2 mb-2">
              <img src="${m.avatar || 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150&auto=format&fit=crop&q=70'}" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
              <div>
                <strong class="text-dark small d-block font-display">${m.sender || 'Admin'} <span class="badge bg-primary-subtle text-primary ms-1" style="font-size: 0.65rem;">${m.senderBadge || 'Staff'}</span></strong>
                <span class="text-muted font-mono" style="font-size: 0.7rem;">${m.createdAt ? new Date(m.createdAt).toLocaleDateString() : 'N/A'}</span>
              </div>
            </div>
            <p class="mb-0 text-secondary small leading-relaxed">${m.message || ''}</p>
          </div>
        `;
      });
    }

    /**
     * Submit response message
     */
    document.getElementById("student-msg-form").addEventListener("submit", (e) => {
      e.preventDefault();
      const recipient = document.getElementById("student-msg-recipient").value;
      const text = document.getElementById("student-msg-text").value;

      try {
        const msgs = JSON.parse(localStorage.getItem("mock_messages") || "[]");
        const newMsg = {
          id: "msg-" + Date.now(),
          sender: "Me (Student)",
          senderBadge: "Student",
          avatar: currentStudentData.passportPhoto || "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&auto=format&fit=crop&q=80",
          message: `To ${recipient}: ${text}`,
          createdAt: new Date().toISOString()
        };

        msgs.push(newMsg);
        localStorage.setItem("mock_messages", JSON.stringify(msgs));
        
        alert("Success! Inquiry dispatched safely to " + recipient);
        document.getElementById("student-msg-text").value = "";
        loadMessagesList();
      } catch (err) {
        alert("Failed to send message: " + err.message);
      }
    });

    /**
     * Submit Help Ticket
     */
    document.getElementById("support-ticket-form").addEventListener("submit", (e) => {
      e.preventDefault();
      const sub = document.getElementById("ticket-subject").value;
      const cat = document.getElementById("ticket-category").value;
      const desc = document.getElementById("ticket-description").value;

      try {
        const tickets = JSON.parse(localStorage.getItem("mock_support_tickets") || "[]");
        tickets.unshift({
          id: "TCK-" + Date.now(),
          studentId: currentStudentData.studentId,
          subject: sub,
          category: cat,
          description: desc,
          status: "Open",
          createdAt: new Date().toISOString()
        });
        localStorage.setItem("mock_support_tickets", JSON.stringify(tickets));

        alert("Support ticket filed successfully! Ticket code: TCK-" + Date.now() + ". Abuja desk will review details.");
        document.getElementById("support-ticket-form").reset();
      } catch (err) {
        alert("Failed to submit ticket: " + err.message);
      }
    });

    // Homework Submit File Submission integration
    document.getElementById("assignment-upload-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      
      if ((currentStudentData.status || "").toLowerCase() === "pending") {
        alert("Your student account profile is listed as PENDING REVIEW. Please contact registry at Suite B18 Capital Plaza Garki Abuja to approve files.");
        return;
      }

      const fileObj = document.getElementById("homework-file-ref").files[0];
      const btn = document.getElementById("upload-sub-btn");
      const progressAlert = document.getElementById("upload-progress-alert");

      try {
        btn.disabled = true;
        progressAlert.classList.remove("d-none");

        const studentUid = sessionStorage.getItem("student_uid") || "mock_student_uid";
        const downloadUrl = await uploadAssignmentFile(studentUid, currentStudentData.studentId, fileObj);
        
        progressAlert.classList.add("d-none");
        btn.disabled = false;
        alert("Success! Your homework folder has been securely packaged and cataloged inside our database storage. Instructors notified.");
        
        document.getElementById("assignment-upload-form").reset();
        
        // Reload details
        const data = await getStudentProfile(studentUid);
        await renderStudentDashboardWithData(data, studentUid);

      } catch (err) {
        console.error("Upload error:", err);
        btn.disabled = false;
        progressAlert.classList.add("d-none");
        alert("Upload error: " + err.message);
      }
    });

    // Profile updates form submission
    document.getElementById("edit-profile-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const fullname = document.getElementById("edit-fullname").value;
      const phone = document.getElementById("edit-phone").value;
      const gender = document.getElementById("edit-gender").value;
      const dob = document.getElementById("edit-dob").value;
      const state = document.getElementById("edit-state").value;
      const address = document.getElementById("edit-address").value;
      const bio = document.getElementById("edit-bio").value;
      const emergencyName = document.getElementById("edit-emergency-name").value;
      const emergencyPhone = document.getElementById("edit-emergency-phone").value;
      const btn = document.getElementById("edit-profile-sub-btn");

      const studentUid = sessionStorage.getItem("student_uid") || "mock_student_uid";

      try {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Saving database rows...';
        
        const updated = await updateStudentProfile(studentUid, {
          fullname, phone, gender, dob, state, address, bio
        });

        // Add the new fields manually to profile
        updated.emergencyName = emergencyName;
        updated.emergencyPhone = emergencyPhone;
        localStorage.setItem("mock_student_profile", JSON.stringify(updated));
        
        alert("Success! Garki profile records updated successfully.");
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-save-fill me-2"></i> Save Profile Details';
        
        await renderStudentDashboardWithData(updated, studentUid);

      } catch (err) {
        console.error("Edit profile error:", err);
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-save-fill me-2"></i> Save Profile Details';
        alert("Failed to modify database record rows: " + err.message);
      }
    });

    /**
     * Load certificates dynamically based on student course completion status
     */
    async function loadCertificatesList() {
      const container = document.getElementById("certificate-status-container");
      if (!container) return;
      
      const statusLower = (currentStudentData && currentStudentData.status || "approved").toLowerCase();
      
      if (statusLower === "completed") {
        container.innerHTML = `
          <div class="card border-success bg-success-subtle p-4 rounded-4 mb-4">
            <div class="d-flex align-items-center gap-3">
              <div class="p-3 bg-success text-white rounded-circle fs-2"><i class="bi bi-award-fill"></i></div>
              <div class="text-start">
                <h5 class="fw-bold text-success mb-1">Congratulations! Your Academic Certificate is Available</h5>
                <p class="text-muted small mb-0">The central academic desk has fully approved and issued your completion credentials for the <strong>${currentStudentData.course || "Software Engineering"}</strong> programme.</p>
              </div>
            </div>
          </div>
          
          <div class="border rounded-4 p-4 text-center bg-white shadow-sm position-relative overflow-hidden" style="max-width: 700px; margin: 0 auto;">
            <!-- Decorative Border overlay -->
            <div style="position: absolute; border: 15px solid rgba(25, 135, 84, 0.05); top: 10px; bottom: 10px; left: 10px; right: 10px; pointer-events: none; border-radius: 8px;"></div>
            
            <div class="py-4 position-relative z-1">
              <img src="/assets/images/logo-512.png" alt="EJaytech Logo" class="mb-3" style="width: 80px; height: 80px; object-fit: contain;">
              <h2 class="fw-bold font-display text-dark mb-0">EJaytech Concepts</h2>
              <p class="text-muted small mb-4 font-mono">Vocational Software & Technical Training Academy</p>
              
              <p class="mb-1 text-uppercase text-secondary tracking-widest small">This completion credential is proudly awarded to</p>
              <h1 class="fw-bold font-display text-primary my-3" style="font-size: 2rem; border-bottom: 2px solid #2563eb; display: inline-block; padding-bottom: 5px;">${currentStudentData.fullname || currentStudentData.fullName}</h1>
              
              <p class="lead text-secondary my-3" style="font-size: 1rem;">for having successfully satisfied all prescribed registry curriculum pathways, exams, and projects for graduation in the vocational pathway of:</p>
              <h4 class="fw-bold text-dark font-display my-2">${currentStudentData.course || "Software Engineering"}</h4>
              
              <div class="row mt-5 pt-3 align-items-end">
                <div class="col-4">
                  <span class="font-mono text-dark fw-bold" style="font-size: 0.85rem;">${new Date(currentStudentData.createdAt || Date.now()).toLocaleDateString()}</span>
                  <div class="border-top pt-1 mt-2 text-muted small">Date of Admission</div>
                </div>
                <div class="col-4">
                  <div class="p-3 bg-light d-inline-block border rounded-circle text-success mb-2" style="width: 60px; height: 60px; line-height: 25px;"><i class="bi bi-patch-check-fill fs-3"></i></div>
                  <div class="text-muted small">Registry Clear</div>
                </div>
                <div class="col-4">
                  <span class="font-mono text-dark fw-bold" style="font-size: 0.85rem;">EJ-CERT-${currentStudentData.studentId || "XXXX"}</span>
                  <div class="border-top pt-1 mt-2 text-muted small">Certificate ID</div>
                </div>
              </div>
              
              <div class="mt-5 no-print">
                <button class="btn btn-success px-4 py-3 fw-bold" onclick="window.print()"><i class="bi bi-download me-2"></i> Download Digital PDF / Print Certificate</button>
              </div>
            </div>
          </div>
        `;
      } else {
        container.innerHTML = `
          <div class="card p-5 text-center border-0 bg-light rounded-4">
            <div class="p-4 bg-warning-subtle text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
              <i class="bi bi-lock-fill" style="font-size: 2.5rem;"></i>
            </div>
            <h4 class="fw-bold font-display text-dark mb-2">Graduation Certificate Locked</h4>
            <p class="text-muted mx-auto mb-4" style="max-width: 550px;">
              Your completion certificate is currently locked. Once your vocational track duration is complete, all project grading logs are reviewed, and your account is updated to <strong>"Completed"</strong>, your verified digital credential will unlock here for immediate download and print.
            </p>
            <div class="border-top pt-4">
              <span class="badge bg-primary-subtle text-primary py-2 px-3 fw-semibold"><i class="bi bi-info-circle-fill me-1"></i> Current Application Progress: Active Learning Stage</span>
            </div>
          </div>
        `;
      }
    }

    /**
     * Change password form handler
     */
    document.getElementById("change-password-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const currentPwd = document.getElementById("change-current-password").value;
      const newPwd = document.getElementById("change-new-password").value;
      const btn = document.getElementById("change-pwd-sub-btn");
      
      const studentUid = sessionStorage.getItem("student_uid") || "mock_student_uid";

      try {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Saving new keys...';
        
        await changeStudentPassword(studentUid, currentPwd, newPwd);
        
        alert("Success! Security credentials updated successfully.");
        document.getElementById("change-password-form").reset();
      } catch (err) {
        alert("Failed to change credentials: " + err.message);
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-key-fill me-1"></i> Update Security Password';
      }
    });

    /**
     * Resubmit Registration for Centre Admin Review
     */
    window.resubmitRegistrationForApproval = async function() {
      if (!currentStudentData || !currentStudentData.uid) {
        alert("Unable to find student account record.");
        return;
      }
      
      if (!confirm("Are you sure you want to resubmit your registration for Centre Admin review?")) {
        return;
      }

      try {
        const studentUid = currentStudentData.uid;
        currentStudentData.status = "pending";
        currentStudentData.approvalStatus = "pending";
        currentStudentData.rejectionReason = "";
        if (currentStudentData.workflow) {
          currentStudentData.workflow.adminApproval = "pending";
          currentStudentData.workflow.pendingReview = "pending";
        }

        // Save in localStorage
        localStorage.setItem("mock_student_profile", JSON.stringify(currentStudentData));
        
        // Sync in master list
        try {
          const listStr = localStorage.getItem("mock_students_list");
          if (listStr) {
            const list = JSON.parse(listStr);
            const idx = list.findIndex(s => s.uid === studentUid || s.studentId === currentStudentData.studentId);
            if (idx !== -1) {
              list[idx].status = "pending";
              list[idx].approvalStatus = "pending";
              list[idx].rejectionReason = "";
              if (list[idx].workflow) list[idx].workflow.adminApproval = "pending";
              localStorage.setItem("mock_students_list", JSON.stringify(list));
            }
          }
        } catch (e) {
          console.warn("Failed syncing in mock_students_list:", e);
        }

        // Save in Firestore if available
        try {
          if (db) {
            const snap = await db.collection("students").get();
            snap.forEach(async (doc) => {
              const d = doc.data();
              if (d.uid === studentUid || d.studentId === currentStudentData.studentId) {
                await db.collection("students").doc(doc.id).update({
                  status: "pending",
                  approvalStatus: "pending",
                  rejectionReason: "",
                  "workflow.adminApproval": "pending"
                });
              }
            });
          }
        } catch (e) {
          console.warn("Firestore update notice:", e);
        }

        // Dispatch email notification to Centre Admin
        try {
          const adminEmails = {
            abk: "ejaytechabkadmin@gmail.com",
            ibadan: "ejaytechibadmin@gmail.com",
            abuja: "ejaytechabjadmin@gmail.com"
          };
          const adminEmail = adminEmails[currentStudentData.centreId] || "ejaytechadmin@gmail.com";
          await sendEmailNotification("admin_notification", adminEmail, {
            studentName: currentStudentData.fullname || currentStudentData.fullName,
            studentId: currentStudentData.studentId,
            centre: currentStudentData.centre,
            course: currentStudentData.course,
            registrationDate: new Date().toLocaleDateString(),
            reviewLink: `${window.location.origin}/admin-dashboard.html`
          });
        } catch (e) {
          console.warn("Notification error:", e);
        }

        alert("Registration resubmitted successfully for Centre Admin review!");
        await renderStudentDashboardWithData(currentStudentData, studentUid);

      } catch (err) {
        console.error("Resubmit error:", err);
        alert("Failed to resubmit: " + err.message);
      }
    };

    /**
     * Upload Document Helper
     */
    window.uploadStudentDocument = function(docType, input) {
      const file = input.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = async function(e) {
        const base64Url = e.target.result;
        if (!currentStudentData) currentStudentData = {};
        if (!currentStudentData.documents) currentStudentData.documents = {};
        
        currentStudentData.documents[docType] = base64Url;
        
        if (docType === 'passportPhoto') {
          currentStudentData.passportPhoto = base64Url;
          const passImg = document.getElementById("student-passport-photo");
          if (passImg) passImg.src = base64Url;
          const prevImg = document.getElementById("doc-preview-passport");
          if (prevImg) prevImg.src = base64Url;
        } else {
          const prevEl = document.getElementById(`doc-preview-${docType === 'idCard' ? 'idcard' : docType === 'certificates' ? 'certs' : 'supp'}`);
          if (prevEl) prevEl.textContent = `Attached: ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
        }

        localStorage.setItem("mock_student_profile", JSON.stringify(currentStudentData));
        
        try {
          const listStr = localStorage.getItem("mock_students_list");
          if (listStr) {
            const list = JSON.parse(listStr);
            const idx = list.findIndex(s => s.uid === currentStudentData.uid || s.studentId === currentStudentData.studentId);
            if (idx !== -1) {
              list[idx].documents = currentStudentData.documents;
              if (docType === 'passportPhoto') list[idx].passportPhoto = base64Url;
              localStorage.setItem("mock_students_list", JSON.stringify(list));
            }
          }
        } catch (err) {
          console.warn("Doc sync error:", err);
        }

        const statusBadgeId = `doc-status-${docType === 'passportPhoto' ? 'passport' : docType === 'idCard' ? 'idcard' : docType === 'certificates' ? 'certs' : 'supp'}`;
        const badgeEl = document.getElementById(statusBadgeId);
        if (badgeEl) {
          badgeEl.textContent = "Uploaded / Under Review";
          badgeEl.className = "badge bg-info-subtle text-info border";
        }

        alert(`Document (${file.name}) uploaded successfully! Centre Admin will review it.`);
      };
      reader.readAsDataURL(file);
    };
  </script>
</body>
</html>
