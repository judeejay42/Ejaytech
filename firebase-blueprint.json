{
  "entities": {
    "student": {
      "title": "Student",
      "description": "Student profile registration data and training status tracking",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Unique structured student registration number (Format: EJ-YYYY-XXXX)" },
        "fullname": { "type": "string", "description": "Full name of the student" },
        "email": { "type": "string", "format": "email", "description": "User login email address" },
        "phone": { "type": "string", "description": "Active phone numbers" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "dob": { "type": "string", "format": "date", "description": "Date of Birth" },
        "state": { "type": "string", "description": "State of Origin or residence" },
        "address": { "type": "string", "description": "Residential home or contact address" },
        "course": { "type": "string", "description": "Name of the enrolled digital course track" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "lastDocumentSubmitted": { "type": "string" },
        "passportPhoto": { "type": "string", "description": "URL of the student passport photograph" },
        "emailVerified": { "type": "boolean", "description": "Email verification status flag" }
      },
      "required": ["studentId", "fullname", "email", "phone", "gender", "dob", "state", "address", "course", "status", "createdAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Administrative manager authorized list",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePictureUrl": { "type": "string" },
        "darkModeEnabled": { "type": "boolean" },
        "websiteSettings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "email"]
    },
    "course": {
      "title": "Course",
      "description": "Digital learning program catalog details",
      "type": "object",
      "properties": {
        "courseName": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "requirements": { "type": "string" },
        "learningOutcomes": { "type": "string" },
        "courseImage": { "type": "string" },
        "syllabus": { "type": "array" },
        "isArchived": { "type": "boolean" },
        "fee": { "type": "string" }
      },
      "required": ["courseName", "description", "duration", "requirements"]
    },
    "material": {
      "title": "Material",
      "description": "Study worksheets, videos, and reading PDFs uploaded by admins",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "filePath": { "type": "string" },
        "fileSize": { "type": "string" },
        "fileType": { "type": "string", "enum": ["PDF", "Video", "Image", "Assignment"] },
        "courseId": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "filePath", "fileType", "courseId", "uploadedAt"]
    },
    "announcement": {
      "title": "Announcement",
      "description": "General program alerts posted by school administrator appearing for all students",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "createdAt"]
    },
    "notification": {
      "title": "Notification",
      "description": "Student-specific alerts inbox with distinct categories",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Student ID targeted, or 'all'" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "type": { "type": "string", "enum": ["General Notice", "Course Update", "Approval Notification", "Rejection Notification", "Assignment Notification"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "title", "message", "status", "type", "createdAt"]
    }
  },
  "firestore": {
    "/students/{studentIdRaw}": {
      "schema": "student",
      "description": "Document mapping student attributes indexed by their authentication uid"
    },
    "/admins/{adminIdRaw}": {
      "schema": "admin",
      "description": "System admin whitelist mappings"
    },
    "/courses/{courseId}": {
      "schema": "course",
      "description": "Registered academic courses details available"
    },
    "/materials/{materialId}": {
      "schema": "material",
      "description": "Course-specific learning material files"
    },
    "/announcements/{announcementId}": {
      "schema": "announcement",
      "description": "Campus-wide dynamic notice board alerts"
    },
    "/notifications/{notifId}": {
      "schema": "notification",
      "description": "Targeted course or audit alert records"
    }
  }
}
