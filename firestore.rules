rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Access Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Role-based lookup: Check if user has role 'admin' in users collection,
    // or has the admin email.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@ejaytech.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Catch-all Default-Deny rule block
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection Access Rules (Students & Admins)
    match /users/{uid} {
      // Students can read their own profile, anyone can read global website settings (admin-master), admins can read all
      allow read: if isOwner(uid) || isAdmin() || (isSignedIn() && uid == 'admin-master');
      
      // Permit registration creation during initial application process
      allow create: if (
        isSignedIn() && isOwner(uid) && 
        request.resource.data.role == 'student' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.fullname is string && request.resource.data.fullname.size() <= 150 &&
        request.resource.data.email is string && request.resource.data.email.size() <= 150 &&
        request.resource.data.phone is string && request.resource.data.phone.size() <= 30 &&
        request.resource.data.gender is string && 
        request.resource.data.dob is string &&
        request.resource.data.state is string &&
        request.resource.data.address is string && request.resource.data.address.size() <= 500 &&
        request.resource.data.course is string &&
        request.resource.data.studentId is string && request.resource.data.studentId.size() <= 30
      ) || isAdmin();

      // Allow students to modify specific personal details (excluding locked fields),
      // and admins to update everything.
      allow update: if (
        isSignedIn() && isOwner(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status && 
        request.resource.data.studentId == resource.data.studentId && 
        request.resource.data.email == resource.data.email && 
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.keys().hasAll(resource.data.keys()) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullname', 'fullName', 'phone', 'gender', 'dob', 'state', 'address', 'bio', 'lastDocumentSubmitted', 'passportPhoto', 'emailVerified'
        ])
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    // Course Catalogue
    match /courses/{courseId} {
      allow read: if true; // Anyone can read the syllabi and catalogues 
      allow write: if isAdmin();
    }

    // Learning Materials
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Announcements Notice Board
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Notification Alerts & Broadcasts
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // allow student actions (like uploads) to trigger admin notification creations
      // Allow students to dismiss their personal notifications by marking status as 'read'
      allow update: if (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'read']) &&
        request.resource.data.status == 'read'
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Emails Database Sync
    match /emails/{emailId} {
      allow read, write: if isAdmin();
    }
  }
}
