rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Students collection rules: authenticated students can read and update only their own document
    match /students/{studentId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.uid == studentId || request.auth.token.admin == true);
      allow create: if true; // Allow student registration
      allow update: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.uid == studentId || request.auth.token.admin == true);
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // General fallback rule
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
