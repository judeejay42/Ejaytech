rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Access Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Role-based lookup: Admin mapping via Uid document existence in /admins/
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Catch-all Default-Deny rule block
    match /{document=**} {
      allow read, write: if false;
    }

    // Students Collection Access Rules
    match /students/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      
      // Permit registration creation during initial application process
      allow create: if isSignedIn() && isOwner(uid) && 
                      request.resource.data.status == 'Pending' &&
                      request.resource.data.fullname is string && request.resource.data.fullname.size() <= 150 &&
                      request.resource.data.email is string && request.resource.data.email.size() <= 150 &&
                      request.resource.data.phone is string && request.resource.data.phone.size() <= 30 &&
                      request.resource.data.gender is string && 
                      request.resource.data.dob is string &&
                      request.resource.data.state is string &&
                      request.resource.data.address is string && request.resource.data.address.size() <= 500 &&
                      request.resource.data.course is string &&
                      request.resource.data.studentId is string && request.resource.data.studentId.size() <= 30 &&
                      request.resource.data.createdAt == request.time;

      // Allow students to modify specific profile details (excluding locked fields),
      // and admins to update everything in the other branch.
      allow update: if (
        isSignedIn() && isOwner(uid) &&
        request.resource.data.status == resource.data.status && 
        request.resource.data.studentId == resource.data.studentId && 
        request.resource.data.email == resource.data.email && 
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.keys().hasAll(resource.data.keys()) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'fullname', 'phone', 'gender', 'dob', 'state', 'address', 'bio', 'lastDocumentSubmitted', 'passportPhoto', 'emailVerified'
        ])
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    // Dedicated Admins Access whitelist (populated on backend or setup)
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // Course Catalogue
    match /courses/{courseId} {
      allow read: if true; // Anyone can read the syllabi and catalogues 
      allow write: if isAdmin();
    }

    // Learning Materials
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Announcements Notice Board
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Notification Alerts & Broadcasts
    match /notifications/{notifId} {
      allow read: if isSignedIn(); // The client filters queries by studentId == 'all' OR user's standard studentId
      allow create: if isAdmin();
      // Allow students to dismiss their personal notifications by marking status as 'read'
      allow update: if (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status == 'read'
      ) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
